      <input type="text" name="이름" id="xfe_signature_name" />
      <input type="text" name="영어명" id="xfe_signature_en_name" />
      <input type="img" name="로고" id="xfe_signature_logo" />
      <input type="text" name="회사명" id="xfe_signature_componey_name" />
      <input type="text" name="주소" id="xfe_signature_componey_address" />
      <input type="text" name="공장 주소" id="xfe_signature_factory_address" />
      <input type="text" name="Tel" id="xfe_signature_tel" />
      <input type="text" name="Fax" id="xfe_signature_fax" />
      <input type="text" name="Mobile" id="xfe_signature_mobile" />
      <input type="text" name="Email" id="xfe_signature_email" />
    </inputs>
  </template>
