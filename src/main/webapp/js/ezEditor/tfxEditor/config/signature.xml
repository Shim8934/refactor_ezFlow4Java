<?xml version="1.0"?>

<!-- 하나의 템플릿 파일은 하나의 template 태그입니다. -->
<!-- template -->
<!-- title : 서명템플릿 목록에 보여질 파일 명. -->
<!-- show : 파일을 보여줄지 결정. (true: 보임, false: 숨김) -->
<!-- path : 서명 템플릿(html) 파일의 경로. (기준 : 에디터가 존재하는 폴더) -->
<!-- input -->
<!-- type : 입력받는 input의 타입 (img, text 두가지만 존재) -->
<!-- name : label 이름 -->
<!-- id : html의 input id와 동일한 id값을 넣어야합니다. -->
<templates>
  <template title="서명1" show="true" path="/signature/example1.html">
    <inputs>
      <input type="img" name="로고" id="xfe_signature_logo" />
      <input type="text" name="이름" id="xfe_signature_name" />
      <input type="text" name="직책" id="xfe_signature_position" />
      <input type="text" name="팀" id="xfe_signature_team" />
      <input type="text" name="회사번호" id="xfe_signature_tel" />
      <input type="text" name="팩스번호" id="xfe_signature_fax" />
      <input type="text" name="핸드폰" id="xfe_signature_mobile" />
      <input type="text" name="이메일" id="xfe_signature_email" />
      <input type="text" name="주소" id="xfe_signature_company_address" />
    </inputs>
  </template>
