<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" 
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:p="http://www.springframework.org/schema/p"
        xmlns:context="http://www.springframework.org/schema/context"
        xmlns:mvc="http://www.springframework.org/schema/mvc"
        xmlns:websocket="http://www.springframework.org/schema/websocket"
        xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.2.xsd
                http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-3.2.xsd
                http://www.springframework.org/schema/mvc http://www.springframework.org/schema/mvc/spring-mvc-3.2.xsd
                http://www.springframework.org/schema/websocket http://www.springframework.org/schema/websocket/spring-websocket-4.1.xsd">

    <!-- нҢЁнӮӨм§Җ лӮҙ Controller, Service, Repository нҒҙлһҳмҠӨмқҳ auto detectлҘј мң„н•ң mvc м„Өм • -->
    <context:component-scan base-package="egovframework">
        <context:include-filter type="annotation" expression="org.springframework.stereotype.Controller"/>
        <context:exclude-filter type="annotation" expression="org.springframework.stereotype.Service"/>
        <context:exclude-filter type="annotation" expression="org.springframework.stereotype.Repository"/>
    </context:component-scan>

    <!-- м„ңлё”лҰҝм»Ёл„Өмқҙл„ҲмғҒмқҳ exceptionм—җ лҢҖн•ң мҳӨлҘҳ нҺҳмқҙм§ҖлҘј м—°кІ°н•ҳлҠ” mvc м„Өм •-->
    <bean class="org.springframework.web.servlet.handler.SimpleMappingExceptionResolver">
        <property name="defaultErrorView" value="cmm/error/egovError"/>
        <property name="defaultStatusCode" value="500"/>
        <property name="exceptionMappings">
            <props>
                <prop key="org.springframework.dao.DataAccessException">cmm/error/dataAccessFailure</prop>
                <prop key="org.springframework.transaction.TransactionException">cmm/error/transactionFailure</prop>
                <prop key="egovframework.rte.fdl.cmmn.exception.EgovBizException">cmm/error/egovError</prop>
                <prop key="org.springframework.security.AccessDeniedException">cmm/error/accessDenied</prop>
            </props>
        </property>
    </bean>
    
	<!--     л·°лҰ¬м ҲлІ„лЎң jsp м°ҫкё°м „м—җ JSON м°ҫлҠ”лӢӨ -->
    <bean class="org.springframework.web.servlet.view.BeanNameViewResolver" p:order="0"/>

    <!-- нҷ”л©ҙмІҳлҰ¬мҡ© JSP нҢҢмқјлӘ…мқҳ  prefix, suffix мІҳлҰ¬м—җ лҢҖн•ң mvc м„Өм •  -->
    <bean class="org.springframework.web.servlet.view.UrlBasedViewResolver" p:order="1"
	    p:viewClass="org.springframework.web.servlet.view.JstlView"
	    p:prefix="/WEB-INF/jsp/" p:suffix=".jsp"/>
	
    <!-- DispatcherServletмқҙ м°ҫм§Җ лӘ»н•ң URL л“Өмқ„ нҶ°мәЈмқҳ default-servlet м„Өм •мңјлЎң л„ҳкІЁмӨҖлӢӨ -->
    <mvc:default-servlet-handler/>
    
    <!-- лЎңк·ёмқё мІҙнҒ¬к°Җ н•„мҡ”н•ң URLкіј лЎңк·ёмқё м—¬л¶ҖлҘј мІҙнҒ¬н•ҙмӨҖлӢӨ -->
    <mvc:interceptors>
        <mvc:interceptor>
            <mvc:mapping path="/cmm/main/*.do"/>
            <mvc:mapping path="/user/login/*.do"/>
            <mvc:mapping path="/admin/**"/>
            <mvc:mapping path="/ez*/**"/>
            <mvc:exclude-mapping path="/user/login/actionLogin.do"/>
            <mvc:exclude-mapping path="/user/login/actionLogoutWithRedirectUri.do"/>            
            <mvc:exclude-mapping path="/user/login/login.do"/>
            <mvc:exclude-mapping path="/user/login/changeExPassword.do"/>
            <mvc:exclude-mapping path="/ezApprovalG/excelExportOut.do"/>
            <mvc:exclude-mapping path="/ezEmail/downloadAttachCommon.do"/>
            <mvc:exclude-mapping path="/ezEmail/downloadInlineDotNet.do"/>
            <mvc:exclude-mapping path="/ezEmail/readSecureMail.do"/>
            <mvc:exclude-mapping path="/ezEmail/readSecureMailContent.do"/>
            <mvc:exclude-mapping path="/ezEmail/downloadSecureAttach.do"/>
            <mvc:exclude-mapping path="/ezEmail/downloadSecureInline.do"/>
            <mvc:exclude-mapping path="/ezEmail/readExternalRecipient.do"/>
            <mvc:exclude-mapping path="/admin/ezApprovalG/componentListTransfer.do"/>
            <mvc:exclude-mapping path="/ezPortal/componentListTransfer.do"/>     
            <mvc:exclude-mapping path="/ezSystem/util/getSysInfo"/>   
            <mvc:exclude-mapping path="/ezSystem/util/getSysMonitorInfo  "/>          
            <mvc:exclude-mapping path="/ezPortal/componentListTransfer.do"/>      
            <mvc:exclude-mapping path="/ezTalkGate/main.do"/>      
            <mvc:exclude-mapping path="/ezTalkGate/login.do"/>      
            <mvc:exclude-mapping path="/ezConn/**"/>      
            <mvc:exclude-mapping path="/ezUCMessenger/**"/>  
		    <bean class="egovframework.com.cmm.interceptor.AuthenticInterceptor" />
        </mvc:interceptor>
        
        <mvc:interceptor>            
            <mvc:mapping path="/mobile/**"/>
            <mvc:mapping path="/rest/**"/>
            <mvc:exclude-mapping path="/rest/ezwebfolder/**"/>
		    <bean class="egovframework.com.cmm.interceptor.MAuthenticInterceptor" />
        </mvc:interceptor>    

        <mvc:interceptor>            
            <mvc:mapping path="/rest/ezwebfolder/**"/>
            <mvc:exclude-mapping path="/rest/ezwebfolder/login"/>
		    <bean class="egovframework.com.cmm.interceptor.WebfolderAuthenticInterceptor" />
        </mvc:interceptor>    
	</mvc:interceptors>

    <!-- Annotation мқ„ мӮ¬мҡ©н•ҳм§Җ м•ҠлҠ” кІҪмҡ°м—җ лҢҖн•ң MVC мІҳлҰ¬ м„Өм • -->
    <mvc:view-controller path="/cmmn/validator.do" view-name="cmmn/validator"/>
    
    <mvc:resources location="/css/" mapping="/css/**"/>
    <mvc:resources location="/js/" mapping="/js/**"/>
    <mvc:resources location="/images/" mapping="/images/**"/>
    <mvc:resources location="/images_en/" mapping="/images_en/**"/>
    <mvc:resources location="/images_ja/" mapping="/images_ja/**"/>
    <mvc:resources location="/files/" mapping="/files/**"/>
    <mvc:resources location="/docs/" mapping="/docs/**"/>
    
	<bean id="contentNegotiationManager" class="org.springframework.web.accept.ContentNegotiationManagerFactoryBean">
		<property name="favorPathExtension" value="false" />
	</bean>
    
    <mvc:annotation-driven content-negotiation-manager="contentNegotiationManager" />

	<websocket:message-broker application-destination-prefix="/app" user-destination-prefix="/user">		
	    <websocket:stomp-endpoint path="/hello" >  	    	 	
			<websocket:sockjs />
	    </websocket:stomp-endpoint>
	    <websocket:stomp-endpoint path="/websocket" allowed-origins="/*">
			<websocket:handshake-interceptors>
				<bean class="org.springframework.web.socket.server.support.HttpSessionHandshakeInterceptor"></bean>
			</websocket:handshake-interceptors>
		</websocket:stomp-endpoint>
	    <websocket:simple-broker prefix="/reply, /topic, /message, /lad"/>
	</websocket:message-broker>
		
</beans>