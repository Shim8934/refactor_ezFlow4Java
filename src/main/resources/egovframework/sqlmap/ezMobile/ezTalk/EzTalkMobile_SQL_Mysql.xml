<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ezTalkMobile">

	<resultMap class="egovframework.ezMobile.ezTalk.vo.MTalkNotification" id="MTalkNotification">
		<result property="id" column="itemseq" />
		<result property="userId" column="userid" />
		<result property="senderName" column="sender" />
		<result property="subject" column="subject" />
		<result property="type" column="type" />
		<result property="etcData" column="etcdata" />
		<result property="link" column="linkurl" />
		<result property="mgwDeviceInfo" resultMap="ezTalkMobile.MTalkDevice" />
	</resultMap>

	<resultMap class="egovframework.ezMobile.ezTalk.vo.MTalkDevice" id="MTalkDevice">
		<result property="id" column="tdm_devseq" />
		<result property="deviceId" column="tdm_devid" />
		<result property="deviceType" column="tdm_devtype" />
		<result property="userId" column="tdm_userid" />
		<result property="badgeCount" column="tdm_badge" />
		<result property="token" column="tdm_token" />
		<result property="pushState" column="tdm_pushstate" />
	</resultMap>

	<select id="MTalkDao.getNotifications" parameterClass="Map" resultMap="MTalkNotification">
		SELECT
			ttn.itemseq, ttn.userid, ttn.sender, ttn.subject, ttn.type, ttn.etcdata, ttn.linkurl,
			tdm.devseq AS tdm_devseq, tdm.devid AS tdm_devid, tdm.devtype AS tdm_devtype, tdm.userid AS tdm_userid, tdm.badge AS tdm_badge, tdm.token AS tdm_token, tdm.pushstate AS tdm_pushstate
		FROM
			(
				SELECT * FROM talk_tblnotification
				ORDER BY itemseq
				<isNotNull property="limit">
				LIMIT #limit#
				</isNotNull>
			) ttn
		LEFT JOIN tbl_dev_master tdm
		ON ttn.userid = tdm.userid
		and ttn.tenantid = tdm.tenantid
	</select>

	<delete id="MTalkDao.deleteNotifications">
		DELETE FROM talk_tblnotification
		WHERE itemseq IN <iterate property="itemSeqArray" open="(" close=")" conjunction="," >#itemSeqArray[]#</iterate>
	</delete>

	<update id="MTalkDao.updateBadgeCount" parameterClass="Integer">
			UPDATE TBL_DEV_MASTER
			SET BADGE = BADGE + 1
			WHERE DEVSEQ = #id#
	</update>
</sqlMap>


