<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ezOptionMobile">

	<typeAlias alias="MCommonVO" 					type="egovframework.ezMobile.ezOption.vo.MCommonVO"/>
	<typeAlias alias="MOptionVO" 					type="egovframework.ezMobile.ezOption.vo.MOptionVO"/>
	<typeAlias alias="MPortalTimeLineVO"			type="egovframework.ezMobile.ezPortal.vo.MPortalTimeLineVO"/>
    
    <resultMap class="MCommonVO" id="MCommonVO">
      <result property="tenantId"			column="tenant_id"         					columnIndex="1"/>
      <result property="lang"         	 	column="lang"         						columnIndex="2"/>
      <result property="offSet"       		column="timeZone"        					columnIndex="3"/>
      <result property="deptId"	       		column="department"        					columnIndex="4"/>
      <result property="deptName"	     	column="description"        				columnIndex="5"/>
      <result property="deptName2"	       	column="description2"      					columnIndex="6"/>
      <result property="companyId"       	column="physicaldeliveryofficename"        	columnIndex="7"/>
      <result property="companyName"       	column="company"        					columnIndex="8"/>
      <result property="companyName2"      	column="company2"        					columnIndex="9"/>
      <result property="userId"       		column="cn"        							columnIndex="10"/>
      <result property="userName"       	column="displayName"        				columnIndex="11"/>
      <result property="userName2"       	column="displayName2"        				columnIndex="12"/>
      <result property="title"       		column="title"        						columnIndex="13"/>
      <result property="title2"       		column="title2"		        				columnIndex="14"/>      
      <result property="rollInfo"          	column="rollinfo"                       	columnIndex="15"/>
      <result property="userFileUrl"       	column="userFileUrl"   						columnIndex="16"/>
      <result property="email"       		column="email"   							columnIndex="17"/>
    </resultMap>
    
    <resultMap class="MOptionVO" id="MOptionVO">
      <result property="userId"				column="userId"         					columnIndex="1"/>
      <result property="timeZone"          	column="timeZone"         					columnIndex="2"/>
      <result property="lang"       		column="lang"        						columnIndex="3"/>
      <result property="mainType"	      	column="mainType"        					columnIndex="4"/>
      <result property="listCnt"	     	column="listCnt"        					columnIndex="5"/>      
      <result property="useSecurity"       	column="useSecurity"        				columnIndex="6"/>
      <result property="tenantId"       	column="tenant_id"        					columnIndex="7"/>     
    </resultMap>
    
  	<select id="EzOptionDAO.commonInfoWeb" parameterClass="Map" resultMap="MCommonVO">
    	<![CDATA[
	    	SELECT
	    		b.tenant_id,
	    		a.lang,    	
				a.timeZone,		    
			    b.department,
			    b.description,
			    b.description2,
			    b.physicaldeliveryofficename,
			    b.company,
			    b.company2,
			    b.cn,
			    b.displayName,
			    b.displayName2,
			    b.title,
			    b.title2,
                b.extensionattribute1 as rollinfo,
                b.extensionattribute2 as userFileUrl,
                b.mail as email
			FROM
				TBL_USERLOCALINFO a right join TBL_USERMASTER b ON a.userid = b.cn AND a.tenant_id = b.tenant_id
			WHERE
				b.cn = #userId#
			AND
				b.tenant_id = (select tenant_id from TBL_TENANT_SERVERNAME WHERE server_name = #serverName#)
		]]>		
  	</select>
  	
</sqlMap>

