<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ezOrganMobile">
    <typeAlias  alias="MPersonListVO"           type="egovframework.ezMobile.ezOrgan.vo.MPersonListVO"/>
    
	<select id="MOrganDAO.getPersonList" parameterClass="Map" resultClass="MPersonListVO">
        <![CDATA[
            select
                *
            from
                tbl_usermaster
            where
                PHYSICALDELIVERYOFFICENAME = #companyID#
            and
                TENANT_ID = #tenantID#
        ]]>
    </select>
</sqlMap>

