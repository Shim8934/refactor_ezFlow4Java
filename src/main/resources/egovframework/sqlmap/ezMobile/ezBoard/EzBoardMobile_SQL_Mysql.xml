	<select id="MBoardDAO.getListHeader" parameterClass="Map" resultClass="MBoardListHeaderVO">
		<![CDATA[
			SELECT
				CASE #primary# WHEN '1' THEN name1 WHEN '2' THEN name2 WHEN '3' THEN name3 WHEN '4' THEN name4 END name,
				width,
				colname
			FROM
				TBL_BOARD_ITEM_LISTOPTION
			WHERE
				TENANT_ID = #tenantID#
			AND
				LISTTYPE = #listCode#
			AND
				VIEW_FG = 'Y'
			ORDER BY
				SN
		]]>
	</select>
	
	<select id="MBoardDAO.getBoardProperty" parameterClass="Map" resultClass="MBoardInfoVO">
		<![CDATA[
			SELECT 
				boardid,
				CASE #primary# WHEN '1' THEN boardname ELSE boardname2 END boardname,
				treevieworder,
				boardlevel,
				parentboardid,
				boarddescription,
				itemexpires,
				attachsizelimit,
				replynotify,
				boardgroupid,
				alertpostitem,
				gubun,
				url,
				deleteafter,
				boardno,
				portlet,
				onelinereply,
				boardtreepath,
				background,
				formlocation,
				formflag,
				apprflag,
				apprmailflag,
				attributeyn,
				tenant_id
			FROM 
				TBL_BOARD_BOARDINFO 
			WHERE  
				tenant_id = #tenantID#
			AND
				boardid = #boardID#
		]]>
	</select>
</sqlMap>

