	<select id="EzResourceDAO.getAdmFlag" parameterClass="Map" resultMap="resGetAdminFlagVO">
		<![CDATA[
			SELECT
				member_id, access_lvl 
      		FROM
      			EZRESOURCE.RESACL 
      		WHERE
      			companyid	=	#companyID#
      		AND
      			resid	=	#resID#
			AND
				member_id	=	#memberID#      			
		]]>
	</select>
