	<select id="EzPortalDAO.getParentUID" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT
				ParentUID
      		FROM
      			EZPORTAL.TBL_TOPMENU_GENERAL
      		WHERE
      			UID_	=	#parentTopMenuID#
		]]>
	</select>
	
		<select id="EzPortalDAO.getPortalParentUID" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT
				ParentUID
      		FROM
      			EZPORTAL.TBL_PORTALPAGE_GENERAL
      		WHERE
      			UID_	=	#temp#
		]]>
	</select>
	
	<select id="EzPortalDAO.getTBLTopMenuItems" parameterClass="String" resultMap="portalTBLTopMenuItemsVO">
		<![CDATA[
			SELECT
				*
      		FROM
      			($strSQL$) A
      		ORDER BY
      			A.RowPos
		]]>
	</select>
	
	<select id="EzPortalDAO.getTBLPortalPageItemsT" parameterClass="String" resultMap="portalTBLPortalPageItemsVO">
		<![CDATA[
			SELECT DISTINCT
				*
      		FROM
      			($strSQL$) A
      		ORDER BY
      			A.RowPos
		]]>
	</select>
	
	<select id="EzPortalDAO.getTBLPortalPageItemsF" parameterClass="Map" resultMap="portalTBLPortalPageItemsVO">
		<![CDATA[
			SELECT DISTINCT
				*
      		FROM
      			($strSQL$) A
      		WHERE
      			A.UID_ NOT IN (SELECT 
      									UID_ 
      								FROM 
      									ezPortal.TBL_PortalPage_Items_Change
      								WHERE 
      									UID_ = A.UID_ AND PageUID = A.PageUID AND OwnerPageUID = A.OwnerPageUID AND CreatorID = $pUserID$ AND OwnerPageUID = $pTopParentPageID$ AND ChangeFlag = '2'
      								)	
      		ORDER BY
      			A.RowPos
		]]>
	</select>
	
	<select id="EzPortalDAO.getTopUrl" parameterClass="String" resultClass="String">
