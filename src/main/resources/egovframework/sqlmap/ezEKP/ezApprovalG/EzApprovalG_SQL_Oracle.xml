	<select id="EzApprovalG.getUseContInfo1" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid 
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
	        WHERE  
	        	A.containerowndepid = #deptID#
	        ORDER BY 
	        	B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getUseContInfo2" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid 
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
            JOIN 
            	EZAPPROVALG_$companyID$.TBCONTAINERUSEDEP C
            ON 
            	A.containerid = C.containerid
	        WHERE  
	        	C.usedepid = #deptID#
            AND 
            	A.containerowndepid = #deptID#
        	ORDER BY 
        		B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getUseContInfo3" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid,
	            A.containerowndepid
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
            JOIN 
            	EZAPPROVALG_$companyID$.TBCONTAINERUSEDEP C
            ON 
            	A.containerid = C.containerid
	        WHERE  
	        	C.usedepid = #deptID#
            AND 
            	A.containerowndepid <> #deptID#
        	ORDER BY 
        		A.containerowndepid,
        		B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getIsUse" parameterClass="Map" resultClass="String">
		<![CDATA[
			SELECT 
				isuse 
        	FROM 
        		EZAPPROVALG_$companyID$.TBCODELIST 
       		WHERE  
       			code1 = #v_CODE1#
            AND 
            	code2 = #v_CODE2#
        ]]>
	</select>
	
	<select id="EzApprovalG.getAprDocListReceiveSN" parameterClass="Map" resultClass="String">
		<![CDATA[
			SELECT 
				receivesn 
        	FROM 
        		EZAPPROVALG_$companyID$.TBAPRRECEIPTPROCESSINFO 
       		WHERE  
       			docid = #v_DOCID#
            AND 
            	receiveddeptid = #v_RECEIVEDDEPTID#
        ]]>
	</select>
