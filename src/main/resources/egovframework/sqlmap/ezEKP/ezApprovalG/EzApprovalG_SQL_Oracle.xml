<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ezApprovalG">
	<typeAlias  alias="ApprGLeftVO" 					type="egovframework.ezEKP.ezApprovalG.vo.ApprGLeftVO"/>
	<typeAlias  alias="ApprGDocListVO" 					type="egovframework.ezEKP.ezApprovalG.vo.ApprGDocListVO"/>
	<typeAlias  alias="ApprGListHeaderVO" 					type="egovframework.ezEKP.ezApprovalG.vo.ApprGListHeaderVO"/>
	
	<procedure id="EzApprovalG.getListHeader" parameterClass="Map" resultClass="ApprGListHeaderVO">
		{CALL EZAPPROVALG_$companyID$.EZSP_GETLISTHEADER(#v_LISTTYPE#, #v_LANGTYPE#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzApprovalG.getCode2Name" parameterClass="Map" resultClass="String">
		{CALL EZAPPROVALG_$companyID$.EZSP_GETCODE2NAME(#v_CODE1#, #v_CODE2#, #v_LANGTYPE#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzApprovalG.getName2Code" parameterClass="Map" resultClass="String">
		{CALL EZAPPROVALG_$companyID$.EZSP_GETNAME2CODE(#v_CODE1#, #v_NAME#, #v_LANGTYPE#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzApprovalG.getAprDocList" parameterClass="Map" resultClass="ApprGDocListVO">
		{CALL EZAPPROVALG_$companyID$.EZSP_GETAPRDOCLIST(#v_LISTTYPE#, #v_USERID#, #v_USERIDS#, #v_PAGESIZE#, #v_PAGESIZE2#, #v_ORDEROPTION#, #iv_ORDEROPTION2#, #v_BASICORDER#, #v_BASICORDER2#, #v_SPSUBQUERY#, #v_SDOCNO#, #v_SDOCTITLE#, #v_SWRITERNAME#, #v_SWRITERDEPTNAME#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzApprovalG.getAprDocListCount" parameterClass="Map" resultClass="int">
		{CALL EZAPPROVALG_$companyID$.EZSP_GETAPRDOCLISTCOUNT(#v_LISTTYPE#, #v_USERID#, #v_USERIDS#, #v_SPSUBQUERY#, #v_SDOCNO#, #v_SDOCTITLE#, #v_SWRITERNAME#, #v_SWRITERDEPTNAME#, #v_pCount,javaType=java.lang.Integer,jdbcType=DECIMAL,mode=OUT#)}
	</procedure>
	
	<select id="EzApprovalG.getUseContInfo1" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid 
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
	        WHERE  
	        	A.containerowndepid = #deptID#
	        ORDER BY 
	        	B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getUseContInfo2" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid 
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
            JOIN 
            	EZAPPROVALG_$companyID$.TBCONTAINERUSEDEP C
            ON 
            	A.containerid = C.containerid
	        WHERE  
	        	C.usedepid = #deptID#
            AND 
            	A.containerowndepid = #deptID#
        	ORDER BY 
        		B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getUseContInfo3" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid,
	            A.containerowndepid
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
            JOIN 
            	EZAPPROVALG_$companyID$.TBCONTAINERUSEDEP C
            ON 
            	A.containerid = C.containerid
	        WHERE  
	        	C.usedepid = #deptID#
            AND 
            	A.containerowndepid <> #deptID#
        	ORDER BY 
        		A.containerowndepid,
        		B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getIsUse" parameterClass="Map" resultClass="String">
		<![CDATA[
			SELECT 
				isuse 
        	FROM 
        		EZAPPROVALG_$companyID$.TBCODELIST 
       		WHERE  
       			code1 = #v_CODE1#
            AND 
            	code2 = #v_CODE2#
        ]]>
	</select>
	
	<select id="EzApprovalG.getAprDocListReceiveSN" parameterClass="Map" resultClass="String">
		<![CDATA[
			SELECT 
				receivesn 
        	FROM 
        		EZAPPROVALG_$companyID$.TBAPRRECEIPTPROCESSINFO 
       		WHERE  
       			docid = #v_DOCID#
            AND 
            	receiveddeptid = #v_RECEIVEDDEPTID#
        ]]>
	</select>
</sqlMap>