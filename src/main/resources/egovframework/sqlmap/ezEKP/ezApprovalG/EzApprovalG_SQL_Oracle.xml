	<select id="EzApprovalG.getUseContInfo1" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid 
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
	        WHERE  
	        	A.containerowndepid = #deptID#
	        ORDER BY 
	        	B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getUseContInfo2" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid 
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
            JOIN 
            	EZAPPROVALG_$companyID$.TBCONTAINERUSEDEP C
            ON 
            	A.containerid = C.containerid
	        WHERE  
	        	C.usedepid = #deptID#
            AND 
            	A.containerowndepid = #deptID#
        	ORDER BY 
        		B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getUseContInfo3" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				A.containerid ,
	            B.containertypename ,
	            B.containertypename2 ,
	            B.containertypeid,
	            A.containerowndepid
	        FROM 
	        	EZAPPROVALG_$companyID$.TBCONTAINER A
	        JOIN 
	        	EZAPPROVALG_$companyID$.TBCONTAINERTYPE B
	        ON 
	        	A.containertypeid = B.containertypeid
            JOIN 
            	EZAPPROVALG_$companyID$.TBCONTAINERUSEDEP C
            ON 
            	A.containerid = C.containerid
	        WHERE  
	        	C.usedepid = #deptID#
            AND 
            	A.containerowndepid <> #deptID#
        	ORDER BY 
        		A.containerowndepid,
        		B.containertypeid
        ]]>
	</select>
	
	<select id="EzApprovalG.getEA5Value" parameterClass="Map" resultClass="OrganUserVO">
		<![CDATA[
			SELECT 
				cn, 
				displayname, 
				displayname2, 
				extensionattribute5
	   		FROM 
	   			EZHRMASTER.TBLUSERMASTER 
	   		WHERE 
	   			cn IN (#v_CNVALUE#) 
	   		AND 
	   			NVL(extensionattribute5, '' ) != ''
		]]>
	</select>
	
	<select id="EzApprovalG.getSecondApprovalInfo" parameterClass="Map" resultClass="ApprGSecondApprVO">
		<![CDATA[
			SELECT
				A.cn AS userid,
				A.displayname AS username,
				A.displayname2 AS username2,
				A.extensionattribute5,
				B.displayname AS pusername,
				B.displayname2 AS pusername2                                
			FROM 
				EZHRMASTER.TBLUSERMASTER A 
	        INNER JOIN 
	        	EZHRMASTER.TBLUSERMASTER B  
	        ON 
	        	SUBSTR(A.extensionattribute5,0,INSTR(A.extensionattribute5,':')) = B.cn
            WHERE 
            	NVL(A.extensionattribute5,'') != ''
		]]>
	</select>
	
