		<![CDATA[
			DELETE FROM
        		EZAPPROVALG_$companyID$.TBCONTAINERUSEDEP
        	WHERE
        		containerid = #contID#	
	     ]]> 
	</delete>
	
	<delete id="EzApprovalGAdmin.deleteContainerDocState" 			parameterClass="String">
