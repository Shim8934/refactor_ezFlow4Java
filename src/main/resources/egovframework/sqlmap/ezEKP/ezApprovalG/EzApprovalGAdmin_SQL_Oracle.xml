<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ezApprovalGAdmin">
	<typeAlias  alias="ApprGLeftVO" 					type="egovframework.ezEKP.ezApprovalG.vo.ApprGLeftVO"/>
	<typeAlias  alias="ApprGDocStateVO" 				type="egovframework.ezEKP.ezApprovalG.vo.ApprGDocStateVO"/>
	<!--
	<typeAlias  alias="ApprGDocListVO" 					type="egovframework.ezEKP.ezApprovalG.vo.ApprGDocListVO"/>
	<typeAlias  alias="ApprGAprLineVO" 					type="egovframework.ezEKP.ezApprovalG.vo.ApprGAprLineVO"/>
	<typeAlias  alias="ApprGListHeaderVO" 				type="egovframework.ezEKP.ezApprovalG.vo.ApprGListHeaderVO"/> -->
	
	<procedure id="EzApprovalGAdmin.getContainerInfoManage" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			{CALL EZAPPROVALG_$companyID$.EZSP_GETCONTAINERINFOMANAGE(#v_DEPTID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>	
	</procedure>
	
	<procedure id="EzApprovalGAdmin.insertContainerType" parameterClass="Map">
		<![CDATA[
			{CALL EZAPPROVALG_$companyID$.EZSP_INSERTCONTAINERTYPE(#v_CONTTYPENAME#, #v_CONTTYPENAME2#)}
		]]>	
	</procedure>
	
	<procedure id="EzApprovalGAdmin.deleteContainerType" parameterClass="Map" resultClass="String">
		<![CDATA[
			{CALL EZAPPROVALG_$companyID$.EZSP_DELETECONTAINERTYPE(#v_CONTTYPEID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>	
	</procedure>
	
	<procedure id="EzApprovalGAdmin.getContainerToDocStateInfo" parameterClass="Map" resultClass="ApprGDocStateVO">
		<![CDATA[
			{CALL EZAPPROVALG_$companyID$.EZSP_GETCONTAINERTODOCSTATEINF(#cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>	
	</procedure>
	
	<procedure id="EzApprovalGAdmin.getContainerUseDeptInfo" parameterClass="Map" resultClass="ApprGLeftVO">
		<![CDATA[
			{CALL EZAPPROVALG_$companyID$.EZSP_GETCONTAINERUSEDEPTINFO(#v_CONTID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>	
	</procedure>
	
	<select id="EzApprovalGAdmin.getContTypeInfo" parameterClass="String" resultClass="ApprGLeftVO">
		<![CDATA[
			SELECT 
				containertypeid,
				containertypename,
				containertypename2 
        	FROM 
        		EZAPPROVALG_$companyID$.TBCONTAINERTYPE
	     ]]> 
	</select>
	
	<select id="EzApprovalGAdmin.insertContainerContID" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT 
				NVL(MAX(containerid), '0000000000') as contid
        	FROM 
        		EZAPPROVALG_$companyID$.TBCONTAINER
	     ]]> 
	</select>
	
	<insert id="EzApprovalGAdmin.insertContainerDocState" parameterClass="Map">
		<![CDATA[
			INSERT INTO EZAPPROVALG_$companyID$.TBCONTAINERTODOCSTATE(
				containertypeid, 	documentstate
			)VALUES(
				#data1#,			#data2#
			)			
	     ]]> 
	</insert>
	
	<insert id="EzApprovalGAdmin.insertContainer" parameterClass="Map">
		<![CDATA[
			INSERT INTO EZAPPROVALG_$companyID$.TBCONTAINER(
				containerid, 	containertypeid,	containerowndepid
			)VALUES(
				#contID#,		#contType#,			#deptID#
			)			
	     ]]> 
	</insert>
	
	<insert id="EzApprovalGAdmin.insertContainerUseDep" parameterClass="Map">
		<![CDATA[
			INSERT INTO EZAPPROVALG_$companyID$.TBCONTAINERUSEDEP(
				containerid, 	usedepid
			)VALUES(
				#contID#,		#deptID#
			)			
	     ]]> 
	</insert>
	
	<delete id="EzApprovalGAdmin.deleteContainerDocState" parameterClass="String">
		<![CDATA[
			DELETE FROM 
        		EZAPPROVALG_$companyID$.TBCONTAINERTODOCSTATE
	     ]]> 
	</delete>

</sqlMap>