	<insert id="EzApprovalGAdmin.setTaskHistory" 					parameterClass="Map">
		<![CDATA[
			INSERT INTO EZAPPROVALG_$companyID$.TBTASKCODEHISTORY(
				applydate,
				taskcode,
				taskname,
				taskname2,
				changefactor,
				changefactor2,
				beforevalue,
				aftervalue,
				aftervalue2
			)VALUES(
				#v_APPLYDATE#,
				#v_TASKCODE#,
				#v_TASKNAME#,
				#v_TASKNAME2#,
				#v_CHANGEFACTOR#,
				#v_CHANGEFACTOR2#,
				#v_BEFOREVALUE#,
				#v_AFTERVALUE#,
				#v_AFTERVALUE2#
			)
	     ]]> 
	</insert>
	
	<insert id="EzApprovalGAdmin.insertTaskCode" 					parameterClass="Map">
		<![CDATA[
			INSERT INTO EZAPPROVALG_$companyID$.TBTASKCODE(
				taskcode,
				taskname,
				taskname2,
				keepingperiod,
				creationdate,
				kpreason,
				keepingmethod,
				keepingplace,
				displayrecflag,
				displayrectrastime,
				exdisplayfrequency,
				specialcatalogflag,
				sc1,
				sc2,
				sc3,
				displayusage,
				description,
				subcategorycode
			)VALUES(
				#v_TASKCODE#,
				#v_TASKNAME#,
				#v_TASKNAME2#,
				#v_KEEPINGPERIOD#,
				#v_CREATIONDATE#,
				#v_KPREASON#,
				#v_KEEPINGMETHOD#,
				#v_KEEPINGPLACE#,
				#v_DISPLAYRECFLAG#,
				#v_DISPLAYRECTRASTIME#,
				#v_EXDISPLAYFREQUENCY#,
				#v_SPECIALCATALOGFLAG#,
				#v_SC1#,
				#v_SC2#,
				#v_SC3#,
				#v_DISPLAYUSAGE#,
				#v_DESCRIPTION#,
				#v_SUBCATEGORYCODE#
			)
	     ]]> 
	</insert>
	
	<insert id="EzApprovalGAdmin.insertDeptInfo" 					parameterClass="Map">
		<![CDATA[
			INSERT INTO EZAPPROVALG_$companyID$.TBTASK_DEPTINFO(
				createdate,
				description,
				processdeptname,
				processdeptname2,
				tasktransferflag,
				tdeptcode,
				processdeptcode,
				processdate,
				applydate,
				taskcode,
				delflag,
				deletedate,
				organcode
			)
			SELECT
				creationdate,
				NULL,
				#deptName#,
				#deptName2#,
				'0',
				'NULL',
				#deptCode#,
				TO_CHAR(sysdate, 'yyyyMMDDHH24MI'),
				TO_CHAR(sysdate, 'yyyyMMDD'),
				taskcode,
				'0',
				NULL,
				NULL
			FROM
				EZAPPROVALG_$companyID$.TBTASKCODE
			WHERE
				taskcode = #taskCode#
	     ]]> 
	</insert>
	
	<update id="EzApprovalGAdmin.updateContainer" 					parameterClass="Map">
		<![CDATA[
			UPDATE EZAPPROVALG_$companyID$.TBCONTAINER
			SET
				containertypeid = #contType#,
				containerowndepid = #deptID#
			WHERE
				containerid = #contID#					
	     ]]> 
	</update>
	
	<update id="EzApprovalGAdmin.updateTaskCode" 					parameterClass="Map">
		<![CDATA[
			UPDATE EZAPPROVALG_$companyID$.TBTASKCODE
			SET
				taskname = #v_TASKNAME#,
				taskname2 = #v_TASKNAME2#,
				keepingperiod = #v_KEEPINGPERIOD#,
				kpreason = #v_KPREASON#,
				keepingmethod = #v_KEEPINGMETHOD#,
				keepingplace = #v_KEEPINGPLACE#,
				displayrecflag = #v_DISPLAYRECFLAG#,
				displayrectrastime = #v_DISPLAYRECTRASTIME#,
				exdisplayfrequency = #v_EXDISPLAYFREQUENCY#,
				specialcatalogflag = #v_SPECIALCATALOGFLAG#,
				sc1 = #v_SC1#,
				sc2 = #v_SC2#,
				sc3 = #v_SC3#,
				DisplayUsage = #v_DISPLAYUSAGE#,
				Description = #v_DESCRIPTION#,
				SubCategoryCode = #v_SUBCATEGORYCODE#
			WHERE
				taskcode = #v_TASKCODE#					
	     ]]> 
	</update>
	
	<update id="EzApprovalGAdmin.removeTaskCode1" 					parameterClass="Map">
		<![CDATA[
			UPDATE EZAPPROVALG_$companyID$.TBTASKCODE
			SET
				delflag = '1'
			WHERE
				taskcode = #taskCode#					
	     ]]>
	</update>
	
	<update id="EzApprovalGAdmin.removeTaskCode2" 					parameterClass="Map">
		<![CDATA[
			UPDATE EZAPPROVALG_$companyID$.TBTASK_DEPTINFO
			SET
				delflag = '1',
				deletedate = #now#
			WHERE
				taskcode = #taskCode#					
	     ]]>
	</update>
	
	<update id="EzApprovalGAdmin.updateDeptInfo" 					parameterClass="Map">
		<![CDATA[
			UPDATE EZAPPROVALG_$companyID$.TBTASK_DEPTINFO
			SET
				processdate = TO_CHAR(sysdate, 'yyyyMMDDHH24MI'),
				processdeptname = #deptName#,
				processdeptname2 = #deptName2#,
				delflag = '0',
				deletedate = NULL
			WHERE
				taskcode = #taskCode#
			AND
				trim(processdeptcode) = #deptCode#
	     ]]>
	</update>
	
	<update id="EzApprovalGAdmin.removeDeptInfo" 					parameterClass="Map">
		<![CDATA[
			UPDATE EZAPPROVALG_$companyID$.TBTASK_DEPTINFO
			SET
				processdate = TO_CHAR(sysdate, 'yyyyMMDDHH24MI'),
				delflag = '1',
				deletedate = TO_CHAR(sysdate, 'yyyy-MM-DD')
			WHERE
				taskcode = #taskCode#
			AND
				trim(processdeptcode) = #deptCode#
	     ]]>
	</update>
	
