    <!-- 조직도 만들기 위한 쿼리 -->
	<select id="selectDeptList" parameterClass="map" resultMap="deptViewMap">
		select 
			d.CN as id,
			IF(d.extensionattribute1=null
			<isNotEmpty property="companyId">
			or d.CN=#companyId#
			</isNotEmpty>
			,'##',d.EXTENSIONATTRIBUTE1) as parent,
			d.extensionattribute2 as companyId,
			d.DISPLAYNAME$lang$ as text,
			case d.CN
				when d.extensionattribute2 then 'comp'
				else 'dept'
			end as isComp,
			case d.CN
				when u.DEPARTMENT then 'yes'
				else 'no'
			end as myDept
		from
			tbl_deptmaster d 
		left join 
			tbl_usermaster u 
		on 
			d.tenant_id = u.TENANT_ID
		where 
			d.tenant_id = #tenantId#
		and 
		 u.CN = #userId#
		and
			u.tenant_id = #tenantId#
		and 
			(
				((substr(u.EXTENSIONATTRIBUTE1, 3, 1) = 0 
			and 
				d.extensionattribute2 = u.PHYSICALDELIVERYOFFICENAME))
			or
				(substr(u.EXTENSIONATTRIBUTE1, 3, 1) = 1)
			)
			<isNotEmpty property="companyId">
			and 
				d.EXTENSIONATTRIBUTE2 = #companyId#
			</isNotEmpty>
		ORDER BY lpad(ifnull(d.EXTENSIONATTRIBUTE15, 0), 6, 0), d.DISPLAYNAME$lang$
	</select>

	<!-- 회사 리스트를 가져오는 쿼리 -->
	<select id="selectCompanyList" resultClass="companyVO" parameterClass="map">
		select 
			d.CN as companyId,
			d.DISPLAYNAME$lang$ as companyName,
			case d.CN
				when #companyId# then 'selected'
				else 'no'
			end as selected
		from 
			jmocha.tbl_deptmaster d
		left join
			jmocha.tbl_usermaster u on d.tenant_id = u.TENANT_ID
		where
			d.TENANT_ID = #tenantId#
		and 
			u.CN = #userId#
		and 
			u.TENANT_ID = #tenantId#
		and
			(
				((substr(u.EXTENSIONATTRIBUTE1, 3, 1) = 0 
			and
				d.extensionattribute2 = u.PHYSICALDELIVERYOFFICENAME))
			or
				(substr(u.EXTENSIONATTRIBUTE1, 3, 1) = 1)
			)
		and 
			d.extensionattribute2 = d.CN
		order by lpad(ifnull(d.EXTENSIONATTRIBUTE15, 0), 6, 0), d.DISPLAYNAME$lang$
	</select>
	
	
	<!-- 해당부서의 사원리스트 -->
	<select id="selectUserList" parameterClass="Map" resultMap="userMap" remapResults="true">
		select
			DISPLAYNAME$lang$ as user_name,
			CN as user_id,
			TITLE$lang$ as jikwi,
			MAIL as mail,
			DESCRIPTION$lang$ as dept_name,
			EXTENSIONATTRIBUTE2 as user_img
		from 
			tbl_usermaster
		where
			TENANT_ID = #tenantId#
		<isNotEqual property="key" compareValue="DEPARTMENT">
			and 
				$key$ like concat('%',#value#,'%')
		</isNotEqual>
		<isEqual property="key" compareValue="DEPARTMENT">
			and 
				$key$ = #value#
		</isEqual>
		order by 
			lpad(ifnull(EXTENSIONATTRIBUTE15,0),6,0) ,DISPLAYNAME$lang$
	</select>
	
    <insert id="EzPMSDAO.addNewProject" parameterClass="Map">
    	<![CDATA[
    		INSERT INTO tbl_pms_project(
    			tenant_id, 				project_name, 			plan_start_date, 			plan_end_date, 			real_start_date, 
    			head_manager_id, 		head_manager_name,		head_manager_name2, 		head_manager_deptname, 	head_manager_deptname2, 
    			status, 				progress, 				overview, 					weight_input, 			creator_id, 
    			creator_name, 			creator_name2, 			creator_deptname, 			creator_deptname2, 		workingday, 
    			rest_dueday, 			alam_mail_status
    		) 
    		VALUES ( 
    			#tenantId#,				#projectName#,			#planStartDate#,			#planEndDate#,			#realStartDate#, 
    			#headManagerId#,		#headManagerName#,		#headManagerName2#,			#headManagerDeptName#,	#headManagerDeptName2#,	
    			#status#,				#progress#,				#overview#,					#weightInput#,			#creatorId#, 
    			#creatorName#,			#creatorName2#,			#creatorDeptName#,			#creatorDeptName2#,		#workingday#,
    			#restDueday#,			#alamMailStatus#
    		)
    	]]>
    </insert>
    
    <select id="EzPMSDAO.getProjectTaskTree" parameterClass="Map" resultMap="projectTaskTreeVO">
			<![CDATA[
				SELECT
					GROUP_ID AS id,
					UPPER_GROUP_ID AS parent,
					GROUP_NAME AS text,
					SORT_ORDER AS sort
				FROM TBL_PMS_GROUP
				WHERE PROJECT_ID = #project_Id#
			]]>
	</select>
	
	
