	<insert id="EzBoardAdminDAO.getBoardTree_Set" parameterClass="Map">
		<isEqual property="v_STRLANG" compareValue="2">
			<![CDATA[
				INSERT INTO EZBOARDSTD.TBL_Board_TreeCache ( 
					QUERY, 		RESULT2 , 	TENANT_ID 
				)
	        	VALUES ( 
	        		#v_PQUERY#, #v_RESULT#, #v_TENANTID#
