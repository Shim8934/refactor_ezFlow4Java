<!-- 	<procedure id="EzBoardAdminDAO.addMyBoards" parameterClass="Map"> -->
<!-- 		{CALL EZBOARDSTD.EZSP_BRDADDTOMYBOARDS(#v_PUSERID#, #v_PBOARDID#)} -->
<!-- 	</procedure> -->
	
	<insert id="EzBoardAdminDAO.addMyBoards" parameterClass="Map">
		<![CDATA[
			INSERT INTO EZBOARDSTD.TBL_Board_MyBoards ( 
				USERID, BOARDID, BOARDNAME, BOARDNAME2, TREEVIEWNUM, VIEWORDER, TENANT_ID 
			)
         	( SELECT 
         		v_PUSERID ,
              	BOARDID ,
                BOARDNAME ,
                BOARDNAME2 ,
                ( SELECT 
                	COUNT(BOARDID) + 1
     			  FROM 
     			  	EZBOARDSTD.TBL_Board_MyBoards 
     			  WHERE
     			  	TENANT_ID = #v_TENANTID#
     			  AND  
     			  	USERID = #v_PUSERID# ),
                ( SELECT 
                	NVL(MAX(VIEWORDER), 1) + 1 
                  FROM 
                  	EZBOARDSTD.TBL_Board_MyBoards 
                  WHERE  
                  	TENANT_ID = #v_TENANTID#
                  AND
                  	USERID = #v_PUSERID# ),
                TENANT_ID
           	  FROM 
           	  	EZBOARDSTD.TBL_Board_BoardInfo 
           	  WHERE
           	  	TENANT_ID = #v_TENANTID#
           	  AND
           	  	BOARDID = #v_PBOARDID# )
		]]>
	</insert>
	
