	<select id="EzBoardAdminDAO.checkApplyUser" resultMap="checkApplyUser">
		<![CDATA[
			SELECT 
				DISTINCT appruserid 
			FROM 
				ezBoardSTD.TBL_BOARD_APPRLIST
		]]>
	</select>
	
	<select id="EzBoardAdminDAO.get_Admin_TopBoardList" resultMap="brdBoardTree" parameterClass="java.lang.String">
		<![CDATA[
			SELECT 
				boardid,
				boardname,
				boardname2,
				'' as treevieworder,
				'' as boardcolor,
				'' as gubun,
				'' as boardgroupacl
			FROM 
				ezBoardSTD.TBL_Board_BoardInfo
			WHERE
				parentboardid = #parentBoardID#
		]]>
	</select>	
	
	<!-- 	권한가져오기 -->
	<select id="EzBoardAdminDAO.getACL"  parameterClass="java.util.Map" resultClass="BoardPropertyVO">
		<![CDATA[
			SELECT 
				boardid,
	            accessid ,
	            accessname ,
	            accessname2 ,
	            accesslevel ,
	            access_ ,
	            parentboardid ,
	            boardadmin_fg ,
	            listview_fg ,
	            read_fg ,
	            write_fg ,
	            reply_fg ,
	            delete_fg ,
	            inherit_fg ,
	            postnotice ,
	            boardgroupacl  
	       FROM 
	        	ezBoardSTD.TBL_BOARD_BOARDMANAGE 
	       WHERE  
	       		boardid = #pBoardID# 
	       AND 
	       		accessid = #userDeptPath# 
	       AND 
	       		rownum <= 1 
		]]>
	</select>	
	
	<select id="EzBoardAdminDAO.getBackGroundImage"  resultMap="backGroundImage">
		<![CDATA[
			SELECT 
				backgroundid,
	            orgfilename ,
	            savefilename ,
	            reguserid ,
	            regdate ,
	            isuse ,
	            sn ,
	            width ,
	            height
	       FROM 
	        	ezBoardSTD.TBL_BOARD_BOARDBACKGROUNDINFO	       
		]]>
		<dynamic prepend="WHERE">
			<isNotEmpty property="backgroundID"> backgroundid = #backgroundID#</isNotEmpty>
		</dynamic>
		ORDER BY sn
	</select>
	
	<select id="EzBoardAdminDAO.getBoardAttribute" resultClass="BoardAttributeVO">
		<![CDATA[	
			SELECT 
				boardid ,
				tablecol ,
				sn ,
				colname1 ,
				colname2 ,
       			value ,
       			coltype ,
       			must  
	       FROM 
	       		ezBoardSTD.TBL_BOARD_BOARDINFO_ATTRIBUTE 
	       WHERE  
	       		boardid = #boardID#
	       ORDER BY 
	       		sn
		]]>
	</select>
	
	<insert id="EzBoardAdminDAO.saveAttribute" parameterClass="BoardAttributeVO">
		<![CDATA[
			INSERT INTO	ezBoardSTD.TBL_BOARD_BOARDINFO_ATTRIBUTE(
				boardid, 	tablecol, 		sn, 	colname1,	 	colname2, 		value, 		coltype, 	must	
			)
			VALUES(
				#boardID#, 	#tableCol#, 	#sn#, 	#colName1#,	 	#colName2#, 	#value#, 	#colType#, 	#must#
			)		
		]]>		
	</insert>
	
	<insert id="EzBoardAdminDAO.saveHeader" parameterClass="BoardListHeaderVO">
		<![CDATA[
			INSERT INTO	ezBoardSTD.TBL_BOARD_ITEM_LISTOPTION_BOAR(
				boardid, 	sn, 	name1, 		name2,	 	name3, 		name4, 		colname, 		width,		view_fg
			)
			VALUES(
				#boardID#, 	#sn#, 	#name1#, 	#name2#,	#name3#, 	#name4#, 	#colName#, 		#width#,	#name#
			)		
		]]>		
	</insert>
	
	<update id="EzBoardAdminDAO.statusChangeBackGroundImage" parameterClass="BoardBackgroundVO">		
		UPDATE ezBoardSTD.TBL_BOARD_BOARDBACKGROUNDINFO
		SET
			<isEqual property="type" compareValue="U"> isuse = #isUse#</isEqual>
			<isNotEqual property="type" compareValue="U"> sn = #isUse#</isNotEqual>
		WHERE
			backgroundid = #backgroundID#			
	</update>
	
	<update id="EzBoardAdminDAO.updateAttribute" parameterClass="BoardAttributeVO">
		<![CDATA[		
			UPDATE ezBoardSTD.TBL_BOARD_BOARDINFO
			SET
				attributeyn = #value#	
			WHERE
				boardid = #boardID#
		]]>					
	</update>
	
	<delete id="EzBoardAdminDAO.deleteBackGroundImage" parameterClass="BoardBackgroundVO">		
		DELETE FROM 
			ezBoardSTD.TBL_BOARD_BOARDBACKGROUNDINFO		
		WHERE
			backgroundid = #backgroundID#			
	</delete>
	
	<delete id="EzBoardAdminDAO.deleteAttribute" parameterClass="java.lang.String">
		DELETE FROM 
			ezBoardSTD.TBL_BOARD_BOARDINFO_ATTRIBUTE		
		WHERE
			boardid = #boardID#			
	</delete>
	
	<delete id="EzBoardAdminDAO.deleteHeader" parameterClass="java.lang.String">
		DELETE FROM 
			ezBoardSTD.TBL_BOARD_ITEM_LISTOPTION_BOAR		
		WHERE
			boardid = #boardID#			
	</delete>
	
	<delete id="EzBoardAdminDAO.trunkBoard">
		TRUNCATE TABLE 
			ezBoardSTD.TBL_BOARD_TREECACHE		
	</delete>

