	<insert id="EzBoardAdminDAO.setMyBoardTreeConfig_N" parameterClass="MyFavoriteVO">
		<![CDATA[
			INSERT INTO EZBOARDSTD.TBL_Board_MyTree ( 
				TREEID, USERID, TREENAME, TREENAME2, TREESTEP, TREEUPPER, TREEBOARDID, TENANT_ID 
			)
            VALUES ( 
            	#treeId#, #userId#, #treeName#, #treeName2#, ( SELECT NVL(MAX(TREESTEP), 0) + 1 FROM EZBOARDSTD.TBL_Board_MyTree WHERE TENANT_ID = #tenantID# AND TREEUPPER = #treeUpper# ), #treeUpper#, #boardId#, #tenantID# 
            )
		]]>
	</insert>
	
	<update id="EzBoardAdminDAO.setMyBoardTreeConfig_M" parameterClass="MyFavoriteVO">
		<![CDATA[
			UPDATE EZBOARDSTD.TBL_Board_MyTree
		    SET 
		    	TREENAME = #treeName#,
		    	TREENAME2 = #treeName2#
            WHERE
            	TENANT_ID = #tenantID#
            AND  
            	TREEID = #treeUpper#
            AND 
            	USERID = #userId#
		]]>
	</update>
	
	<delete id="EzBoardAdminDAO.setMyBoardTreeConfig_D" parameterClass="MyFavoriteVO">
		<![CDATA[
			DELETE EZBOARDSTD.TBL_Board_MyTree
			WHERE  
				TENANT_ID = #tenantID#
			AND
				( TREEID = #treeUpper#
            	  AND USERID = #userId# )
            OR 
            	TREEUPPER = #treeUpper#
		]]>
	</delete>
	
<!-- 	<procedure id="EzBoardAdminDAO.setMyBoardTreeMoveCopy" parameterClass="MyFavoriteVO"> -->
<!-- 		{CALL EZBOARDSTD.EZSP_SETMYBOARDTREE_MOVECOPY(#userId#, #selTreeID#, #moveTreeID#, #mode#)} -->
<!-- 	</procedure> -->
	
	<update id="EzBoardAdminDAO.setMyBoardTreeMoveCopy" parameterClass="MyFavoriteVO">
		<![CDATA[
			UPDATE EZBOARDSTD.TBL_Board_MyTree
            SET 
            	TREEUPPER = #moveTreeID#,
            	TREESTEP = ( SELECT 
            					COUNT(TREENAME) + 1 
                             FROM 
                             	EZBOARDSTD.TBL_Board_MyTree 
                             WHERE  
                             	TREEUPPER = #moveTreeID#
                             AND 
                             	USERID = #userId# )
            WHERE  
            	TENANT_ID = #tenantID#
            AND
            	TREEID = #selTreeID#
            AND 
            	USERID = #userId#
		]]>
	</update>
	
