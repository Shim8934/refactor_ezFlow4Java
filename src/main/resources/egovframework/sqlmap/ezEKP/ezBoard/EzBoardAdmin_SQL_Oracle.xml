<!-- 	<procedure id="EzBoardAdminDAO.getBoardTree_Get2" parameterClass="Map" resultMap="getBoardTree_Get2" remapResults="true"> -->
<!-- 		{CALL EZBOARDSTD.EZSP_GETBOARDTREE_GET2(#v_PACCESSID#, #v_PROOTBOARDID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)} -->
<!-- 	</procedure> -->
	
	<select id="EzBoardAdminDAO.getBoardTree_Get2" parameterClass="Map" resultMap="getBoardTree_Get2" remapResults="true">
		<![CDATA[
			SELECT 
				BOARDID || ';' BOARDID  
	        FROM 
	        	EZBOARDSTD.TBL_Board_BoardManage 
	        WHERE
	        	TENANT_ID = #v_TENANTID#
	        AND  
	        	ACCESS_ = 0
	        AND 
	        	ACCESSID = #v_PACCESSID#
	        AND 
	        	PARENTBOARDID = #v_PROOTBOARDID#
		]]>
	</select>
	
<!-- 	<procedure id="EzBoardAdminDAO.getMyBoardTree_get3" parameterClass="Map" resultMap="getMyBoardTree_get3" remapResults="true"> -->
<!-- 		{CALL EZBOARDSTD.EZSP_GETMYBOARDTREE_GET3(#v_PUSERID#, #v_PTREEUPPER#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)} -->
<!-- 	</procedure> -->
	
	<select id="EzBoardAdminDAO.getMyBoardTree_get3" parameterClass="Map" resultMap="getMyBoardTree_get3">
		<![CDATA[
			SELECT 
				TREEID ,
             	USERID ,
             	TREENAME ,
             	TREENAME2 ,
             	TREELEVEL ,
             	TREESTEP ,
             	TREEUPPER ,
             	(SELECT 
             		COUNT(*)
     			FROM 
     				EZBOARDSTD.TBL_Board_MyTree 
    			WHERE  
    				TENANT_ID = #v_TENANTID#
    			AND
    				TREEUPPER = A.TREEID) CHILDCNT,
             	TREEBOARDID 
        	FROM 
        		EZBOARDSTD.TBL_Board_MyTree A
       		WHERE  
       			TENANT_ID = #v_TENANTID#
       		AND
       			( USERID = #v_PUSERID#
                  OR USERID = 'everyone' )
            AND 
            	TREEUPPER = #v_PTREEUPPER#
        	ORDER BY 
        		TREESTEP ASC
		]]>
	</select>
		
<!-- 	<procedure id="EzBoardAdminDAO.brdBoardTree" parameterClass="Map" resultMap="brdBoardTree"> -->
<!-- 		{CALL EZBOARDSTD.EZSP_BRDBOARDTREE(#v_pRootBoardID#, #v_pUserID#, #v_pDeptID#, #v_pCompanyID#, #v_pMode#, #v_pSelectBy#,  -->
<!-- 										   #v_pExcludeBoardID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)} -->
<!-- 	</procedure> -->
	
	<select id="EzBoardAdminDAO.brdBoardTree" parameterClass="Map" resultMap="brdBoardTree">
		<isEqual property="v_pMode" compareValue="1">
			<isEqual property="v_pSelectBy" compareValue="3">
<!-- 				쓰기 권한이 있는 게시판만 가져옴 -->
				<![CDATA[
					SELECT 
						DISTINCT A.boardid BoardID,
	                    A.boardname BoardName,
	                    A.boardname2 BoardName2,
	                    A.treevieworder TreeViewOrder,
	                    A.boardcolor BoardColor,
	                    A.gubun,
	                    '' BoardGroupACL
	              	FROM 
	              		EZBOARDSTD.TBL_Board_BoardInfo A
	                JOIN 
	                	(  SELECT 
	                	   	   boardid ,
	                           accessid ,
	                           access_ 
	                       FROM 
	                       	   EZBOARDSTD.TBL_Board_BoardManage 
	                       WHERE
	                       	   TENANT_ID = #v_TENANTID#
	                       AND  
	                       	   parentboardid = #v_pRootBoardID#
	                       AND 
	                           access_ = 1
	                       AND 
	                       	   write_fg = 'true'
	                       AND 
	                       	   boardid <> #v_pExcludeBoardID#
	                       AND 
	                       	   ( accessid = #v_pUserID#
	                             OR accessid = #v_pDeptID#
	                             OR accessid = #v_pCompanyID# ) 
	                     ) B   
	                ON 
	                	a.boardid = b.boardid
	                AND
	                	a.TENANT_ID = b.TENANT_ID
	              	ORDER BY 
	              		A.treevieworder ASC
				]]>
			</isEqual>
			<isNotEqual property="v_pSelectBy" compareValue="3">
<!-- 				접근 권한이 있는 게시판만 가져옴(DEFAULT) -->
				<![CDATA[
					SELECT 
						DISTINCT A.BoardID BoardID  ,
	                    A.BoardName BoardName  ,
	                    A.BoardName2 BoardName2  ,
	                    A.TreeViewOrder TreeViewOrder  ,
	                    A.BoardColor BoardColor  ,
	                    A.Gubun ,
	                    B.BOARDGROUPACL BOARDGROUPACL  
	                FROM 
	                	EZBOARDSTD.TBL_Board_BoardInfo A
	                JOIN 
	                	( SELECT 
	                		C.BoardID ,
	                        C.AccessID ,
	                        C.Access_ ,
	                        C.BoardGroupACL 
	                      FROM 
	                      	EZBOARDSTD.TBL_Board_BoardManage C
	                      LEFT JOIN 
	                      	EZBOARDSTD.TBL_Board_BoardInfo D   
	                      ON 
	                      	C.BoardID = D.BoardID
	                      AND
	                      	C.TENANT_ID = D.TENANT_ID
	                      WHERE
	                      	C.TENANT_ID = #v_TENANTID#
	                      AND
	                      	C.Access_ = 1
	                      AND 
	                      	C.BoardID <> #v_pExcludeBoardID#
	                      AND 
	                      	( C.AccessID = #v_pUserID# )
	                      AND 
	                      	D.ParentBoardID = #v_pRootBoardID# ) B   
	                ON 
	                	A.BoardID = B.BOARDID
	                AND
	                	A.TENANT_ID = B.TENANT_ID
	                ORDER BY 
	                	A.TreeViewOrder ASC
	        	]]>
			</isNotEqual>
		</isEqual>
		<isNotEqual property="v_pMode" compareValue="1">
<!-- 			ADMIN권한 -->
			<![CDATA[
				SELECT 
					DISTINCT A.BoardID ,
                    A.BoardName ,
                    A.BoardName2 ,
                    A.TreeViewOrder ,
                    A.BoardColor BoardColor,
                    A.Gubun ,
                    '' BoardGroupACL
           		FROM 
           			EZBOARDSTD.TBL_Board_BoardInfo A
          		WHERE
          			A.TENANT_ID = #v_TENANTID#
          		AND
          			A.PARENTBOARDID = #v_pRootBoardID#
                AND 
                	A.BoardID <> #v_pExcludeBoardID#
           		ORDER BY 
           			A.TreeViewOrder ASC
			]]>
		</isNotEqual>
	</select>
	
