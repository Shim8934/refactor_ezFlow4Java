<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ezBoardAdmin">
	
	<typeAlias  alias="BoardTreeVO" type="egovframework.ezEKP.ezBoard.vo.BoardTreeVO"/>
	<typeAlias  alias="EzBoardVO" type="egovframework.ezEKP.ezBoard.vo.EzBoardVO"/>
	<typeAlias  alias="BoardPropertyVO" type="egovframework.ezEKP.ezBoard.vo.BoardPropertyVO"/>
	<typeAlias  alias="MyFavoriteVO" type="egovframework.ezEKP.ezBoard.vo.MyFavoriteVO"/>
	
	<resultMap id="getBoardTree_Get2" class="EzBoardVO">
		<result property="boardId" column="BOARDID" columnIndex="1"/>
	</resultMap>
	
	<resultMap id="checkApplyUser" class="EzBoardVO">
		<result property="apprUserId" column="APPRUSERID" columnIndex="1"/>
	</resultMap>
	
	<resultMap id="brdBoardTree" class="BoardTreeVO">
		<result property="boardId" column="BOARDID" columnIndex="1"/>
		<result property="boardName" column="BOARDNAME" columnIndex="2"/>
		<result property="boardName2" column="BOARDNAME2" columnIndex="3"/>
		<result property="treeViewOrder" column="TREEVIEWORDER" columnIndex="4"/>
		<result property="boardColor" column="BOARDCOLOR" columnIndex="5"/>
		<result property="guBun" column="GUBUN" columnIndex="6"/>
		<result property="boardGroupAcl" column="BOARDGROUPACL" columnIndex="7"/>
	</resultMap>
	
	<resultMap class="MyFavoriteVO" id="getMyBoardTree_get3">
		<result property="treeId" column="TREEID" columnIndex="1"/>
		<result property="userId" column="USERID" columnIndex="2"/>
		<result property="treeName" column="TREENAME" columnIndex="3"/>
		<result property="treeName2" column="TREENAME2" columnIndex="4"/>
		<result property="treeLevel" column="TREELEVEL" columnIndex="5"/>
		<result property="treeStep" column="TREESTEP" columnIndex="6"/>
		<result property="treeUpper" column="TREEUPPER" columnIndex="7"/>
		<result property="childCnt" column="CHILDCNT" columnIndex="8"/>
		<result property="treeBoardId" column="TREEBOARDID" columnIndex="9"/>
	</resultMap>
	
	<procedure id="EzBoardAdminDAO.getBoardTree_Get1" parameterClass="Map" resultClass="String">
		{CALL EZBOARDSTD.EZSP_GETBOARDTREE_GET1(#v_STRLANG#,#v_PQUERY#,#cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>

	<procedure id="EzBoardAdminDAO.getBoardTree_Get2" parameterClass="Map" resultMap="getBoardTree_Get2">
		{CALL EZBOARDSTD.EZSP_GETBOARDTREE_GET2(#v_PACCESSID#, #v_PROOTBOARDID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzBoardAdminDAO.getMyBoardTree_get3" parameterClass="Map" resultMap="getMyBoardTree_get3">
		{CALL EZBOARDSTD.EZSP_GETMYBOARDTREE_GET3(#v_PUSERID#, #v_PTREEUPPER#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
		
	<procedure id="EzBoardAdminDAO.brdBoardTree" parameterClass="Map" resultMap="brdBoardTree">
		{CALL EZBOARDSTD.EZSP_BRDBOARDTREE(#v_pRootBoardID#, #v_pUserID#, #v_pDeptID#, #v_pCompanyID#, #v_pMode#, #v_pSelectBy#, 
																						 #v_pExcludeBoardID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzBoardAdminDAO.checkIfLeafBoard" parameterClass="Map" resultClass="Integer">
		{CALL EZBOARDSTD.EZSP_CHECKIFLEAFBOARD(#v_PBOARDID#, #v_pCount,javaType=java.lang.Integer,jdbcType=DECIMAL,mode=OUT#)}
	</procedure>
	
	<procedure id="EzBoardAdminDAO.getBoardTree_Set" parameterClass="Map" >
		{CALL EZBOARDSTD.EZSP_GETBOARDTREE_SET(#v_STRLANG#, #v_PQUERY#, #v_RESULT#)}
	</procedure>
	
	<procedure id="EzBoardAdminDAO.checkIfBoardGroupAdmin" parameterClass="Map" >
		{CALL EZBOARDSTD.EZSP_BRDCHECKIFBOARDGROUPADMIN(#v_pBoardID#, #v_pUserID#, #v_pDeptID#, #v_pCompanyID#, #v_pCount,javaType=java.lang.Integer,jdbcType=DECIMAL,mode=OUT#)}
	</procedure>
	
	<select id="EzBoardAdminDAO.checkApplyUser" resultMap="checkApplyUser">
		<![CDATA[
			SELECT 
				DISTINCT appruserid 
			FROM 
				ezBoardSTD.TBL_BOARD_APPRLIST
		]]>
	</select>
	
	<select id="EzBoardAdminDAO.get_Admin_TopBoardList" resultMap="brdBoardTree" parameterClass="java.lang.String">
		<![CDATA[
			SELECT 
				boardid,
				boardname,
				boardname2,
				'' as treeViewOrder,
				'' as boardColor,
				'' as guBun
			FROM 
				ezBoardSTD.TBL_Board_BoardInfo
			WHERE
				parentboardid = #parentBoardID#
		]]>
	</select>
	
	<select id="EzBoardAdminDAO.createBoardGroup" resultClass="int" parameterClass="EzBoardVO">
		SELECT 
			count(*)
		FROM 
			ezBoardSTD.TBL_Board_BoardInfo		
	</select>
	<!-- 	권한가져오기 -->
	<select id="EzBoardAdminDAO.getACL"  parameterClass="java.util.Map" resultClass="BoardPropertyVO">
		<![CDATA[
			SELECT 
				boardid,
	            accessid ,
	            accessname ,
	            accessname2 ,
	            accesslevel ,
	            access_ ,
	            parentboardid ,
	            boardadmin_fg ,
	            listview_fg ,
	            read_fg ,
	            write_fg ,
	            reply_fg ,
	            delete_fg ,
	            inherit_fg ,
	            postnotice ,
	            boardgroupacl  
	       FROM 
	        	ezBoardSTD.TBL_BOARD_BOARDMANAGE 
	       WHERE  
	       		boardid = #pBoardID# 
	       AND 
	       		accessid = #userDeptPath# 
	       AND 
	       		rownum <= 1 
		]]>
	</select>

</sqlMap>
