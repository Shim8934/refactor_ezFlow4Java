<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ezBoard">
	<typeAlias  alias="EzBoardVO" type="egovframework.ezEKP.ezBoard.vo.EzBoardVO"/>
	<typeAlias  alias="BoardListVO" type="egovframework.ezEKP.ezBoard.vo.BoardListVO"/>
	<typeAlias  alias="MyFavoriteVO" type="egovframework.ezEKP.ezBoard.vo.MyFavoriteVO"/>
	<typeAlias  alias="BoardConfigVO" type="egovframework.ezEKP.ezBoard.vo.BoardConfigVO" />
	<typeAlias  alias="BoardPropertyVO" type="egovframework.ezEKP.ezBoard.vo.BoardPropertyVO"/>
	<typeAlias  alias="BoardListHeaderVO" type="egovframework.ezEKP.ezBoard.vo.BoardListHeaderVO"/>

	<resultMap id="getLeft_boardSTD" class="egovframework.ezEKP.ezBoard.vo.EzBoardVO">
		<result property="boardGroupId" column="BOARDGROUPID" columnIndex="1"/>
	</resultMap>
	
	<resultMap id="get_favoriteList" class="MyFavoriteVO">
		<result property="boardId" column="BOARDID" columnIndex="1"/>
		<result property="boardName" column="BOARDNAME" columnIndex="2"/>
		<result property="boardName2" column="BOARDNAME2" columnIndex="3"/>
		<result property="tabUsed" column="TABUSED" columnIndex="4"/>
		<!-- <result property="guBun" column="GUBUN" columnIndex="5"/> -->
	</resultMap>
	
	<resultMap class="BoardListVO" id="getNewItemList">
		<result property="rNum" column="RNUM" columnIndex="1"/>
		<result property="boardID" column="BOARDID" columnIndex="2"/>
		<result property="boardName" column="BOARDNAME" columnIndex="3"/>
		<result property="itemID" column="ITEMID" columnIndex="4"/>
		<result property="writerID" column="WRITERID" columnIndex="5"/>
		<result property="writerName" column="WRITERNAME" columnIndex="6"/>
		<result property="writerDeptName" column="WRITERDEPTNAME" columnIndex="7"/>
		<result property="writerCompanyName" column="WRITERCOMPANYNAME" columnIndex="8"/>
		<result property="writeDate" column="WRITEDATE" columnIndex="9"/>
		<result property="startDate" column="STARTDATE" columnIndex="10"/>
		<result property="parentWriteDate" column="PARENTWRITEDATE" columnIndex="11"/>
		<result property="importance" column="IMPORTANCE" columnIndex="12"/>
		<result property="title" column="TITLE" columnIndex="13"/>
		<result property="attachments" column="ATTACHMENTS" columnIndex="14"/>
		<result property="readCount" column="READCOUNT" columnIndex="15"/>
		<result property="itemLevel" column="ITEMLEVEL" columnIndex="16"/>
		<result property="_abstract" column="ABSTRACT" columnIndex="17"/>
		<result property="boardName2" column="BOARDNAME2" columnIndex="18"/>
		<result property="writerName2" column="WRITERNAME2" columnIndex="19"/>
		<result property="writerDeptName2" column="WRITERDEPTNAME2" columnIndex="20"/>
		<result property="writerCompanyName2" column="WRITERCOMPANYNAME2" columnIndex="21"/>
		<result property="oneLineCnt" column="ONELINECNT" columnIndex="22"/>
		<result property="upperItemIDTree" column="UPPERITEMIDTREE" columnIndex="23"/>
		<result property="docNo" column="DocNo" columnIndex="24"/>
		<result property="notice" column="NOTICE" columnIndex="25"/>
		<result property="guBun" column="GUBUN" columnIndex="26"/>
		<result property="mainContent" column="MAINCONTENT" columnIndex="27"/>
	</resultMap>
	
	<procedure id="EzBoardDAO.getLeft_BoardSTD" parameterClass="Map" resultMap="getLeft_boardSTD">
		{CALL EZBOARDSTD.EZSP_LEFT_BOARDSTD(#v_REDIRECTBOARDID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>

	<procedure id="EzBoardDAO.get_favoriteList" parameterClass="Map" resultMap="get_favoriteList">
		{CALL EZBOARDSTD.EZSP_GET_FAVORITELIST(#v_USERID#, #v_MODE#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzBoardDAO.get_parentBoardName" parameterClass="Map" resultClass="String">
		{CALL EZBOARDSTD.EZSP_GET_PARENTBOARDNAME(#v_BOARDIDLIST#, #v_BOARDCOUNTLIST#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>

	<procedure id="EzBoardDAO.getListHeader" parameterClass="Map" resultClass="BoardListHeaderVO">
		{CALL EZBOARDSTD.EZSP_GETLISTHEADER(#v_PBOARDTYPE#, #v_PSTRLANG#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>

	<procedure id="EzBoardDAO.getNewItemListCount" parameterClass="Map" resultClass="Integer">
		{CALL EZBOARDSTD.EZSP_BRDNEWITEMCOUNT(#v_pUserID#, #v_pNow#, #v_pFromNow#, #v_pCount,javaType=java.lang.Integer,jdbcType=DECIMAL,mode=OUT#)}
	</procedure>

	<procedure id="EzBoardDAO.getPersonalCount" parameterClass="String" resultClass="BoardConfigVO">
		{CALL EZBOARDSTD.EZSP_GETPERSONALCOUNT(#userID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzBoardDAO.setBoardList_Config" parameterClass="Map">
		{CALL EZBOARDSTD.EZSP_SETBOARDLIST_CONFIG(#v_PUSERID#, #v_PLISTCNT#, #v_PREVIEWMODE#, #v_PREVIEWWLIST#, #v_PREVIEWWCONTENT#, #v_PREVIEWHLIST#, #v_PREVIEWHCONTENT#)}
	</procedure>
	
	<procedure id="EzBoardDAO.getNewItemList" parameterClass="Map" resultClass="HashMap">
		{CALL EZBOARDSTD.EZSP_GETNEWITEMLISTXML(#v_PUSERID#, #v_PSTARTROW#, #v_PENDROW#, #v_PTOTALCOUNT#, #iv_PORDERBYSUB#, #v_PORDERBYMAIN#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzBoardDAO.getBrdNewItemCount" parameterClass="Map" resultClass="Integer">
		{CALL EZBOARDSTD.EZSP_BRDNEWITEMCOUNT(#v_pUserID#, #v_pNow#, #v_pFromNow#, #v_pCount,javaType=java.lang.Integer,jdbcType=DECIMAL,mode=OUT#)}
	</procedure>
	
	<procedure id="EzBoardDAO.set_ListOrder" parameterClass="Map">
		{CALL EZBOARDSTD.EZSP_SET_LISTORDER(#v_ORDERBOARDIDLIST#, #v_ORDERBOARDLISTCOUNT#, #v_DELBOARDIDLIST#, #v_DELBOARDLISTCOUNT#, #v_USERID#, #v_ERR_CD,javaType=java.lang.Integer,jdbcType=INTEGER,mode=INOUT#)}
	</procedure>
	
	<procedure id="EzBoardDAO.set_TabUsed" parameterClass="Map">
		{CALL EZBOARDSTD.EZSP_SET_TABUSED(#v_BOARDID#, #v_TABUSED#, #v_USERID#)}
	</procedure>
	
	<select id="EzBoardDAO.getBoardProperty" parameterClass="String" resultClass="BoardPropertyVO">
		<![CDATA[
			SELECT 
				*
			FROM 
				ezBoardSTD.TBL_BOARD_BOARDINFO 
			WHERE  
				boardid = #pBoardID#
		]]>		
	</select>
	<select id="EzBoardDAO.getBoardList_Config"  resultClass="BoardConfigVO">
		<![CDATA[
			SELECT 
				listcount , 
			    preview , 
			    previewwlist ,
			 	previewwcontent ,
			 	previewhlist ,
              	previewhcontent 
        	FROM 
        	    ezBoardSTD.TBL_BOARD_CONFIGURATION 
       		WHERE  
       		    userid = #userID#
		]]>		
	</select>
</sqlMap>
