										 #title#,#contentLocation#,#startDate#,#endDate#,#ABSTRACT#,#attachments#,#upperItemIDTree#,#itemLevel#,#extensionAttribute1#,#extensionAttribute2#,#extensionAttribute3#,
										 #extensionAttribute4#,#extensionAttribute5#,#docPassword#,#writerName2#,#writerDeptName2#,#writerCompanyName2#,#extensionAttribute32#,#topWriterID#,#extensionAttribute6#,
										 #extensionAttribute7#,#extensionAttribute8#,#extensionAttribute9#,#extensionAttribute10#)}
	</procedure>
	
	<select id="EzBoardDAO.getBoardProperty" parameterClass="String" resultClass="BoardPropertyVO">
		<![CDATA[
			SELECT 
				*
			FROM 
				ezBoardSTD.TBL_BOARD_BOARDINFO 
			WHERE  
				boardid = #pBoardID#
		]]>		
	</select>
	
	<select id="EzBoardDAO.getBoardList_Config"  resultClass="BoardConfigVO">
		<![CDATA[
			SELECT 
				listcount , 
			    preview , 
			    previewwlist ,
			 	previewwcontent ,
			 	previewhlist ,
              	previewhcontent 
        	FROM 
        	    ezBoardSTD.TBL_BOARD_CONFIGURATION 
       		WHERE  
       		    userid = #userID#
		]]>		
	</select>
	
	<select id="EzBoardDAO.getNoticePostItemCount" resultClass="Integer">
		<![CDATA[
			SELECT 
				COUNT(itemid) cnt  
	        FROM 
	        	ezBoardSTD.TBL_BOARD_ITEM 
	        WHERE  
	        	boardid = #boardId#
	        AND 
	        	startdate <= TO_CHAR(SYSDATE,'YYYY-MM-DD HH24:MI:SS')
	        AND 
	        	enddate > TO_CHAR(SYSDATE,'YYYY-MM-DD HH24:MI:SS')
	        AND 
	        	extensionattribute1 = '0'
	        AND 
	        	extensionattribute2 = '1'
        ]]>
	</select>
	
	<select id="EzBoardDAO.getCheckApprUserList" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT 
				COUNT(B.appruserid) AS cnt
	        FROM 
	        	ezBoardSTD.TBL_BOARD_ITEM A
	        JOIN 
	        	ezBoardSTD.TBL_BOARD_APPRLIST B   
	        ON 
	        	A.boardid = B.boardid
	        WHERE  
	        	A.itemid = #v_PITEMID#
	        AND 
	        	B.appruserid = #v_PUSERID#
        ]]>	
	</select>
	
	<select id="EzBoardDAO.checkBackGroundImage" resultClass="Integer">
		<![CDATA[
			SELECT 
				COUNT(boardid)
	        FROM 
	        	ezBoardSTD.TBL_BOARD_BOARDINFO 
	        WHERE  
	       		boardid = #boardID#
			AND 
				background = 'Y'
		]]>                
	</select>
	
	<delete id="EzBoardDAO.newItem" parameterClass="String">
		<![CDATA[
			DELETE FROM
				ezBoardSTD.TBL_BOARD_ITEM_ATTACHMENTS
	   		WHERE  
	   			itemid = #itemID#
   		]]>
	</delete>
	
</sqlMap>
