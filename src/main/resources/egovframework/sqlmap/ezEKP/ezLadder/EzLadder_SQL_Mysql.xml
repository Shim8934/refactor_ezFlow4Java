<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ezLadder">
	<typeAlias  alias="LadderBmUserVO" type="egovframework.ezEKP.ezLadder.vo.LadderBmUserVO"/>
	<typeAlias  alias="LadderBmVO" type="egovframework.ezEKP.ezLadder.vo.LadderBmVO"/>
	<typeAlias  alias="LadderCodelistVO" type="egovframework.ezEKP.ezLadder.vo.LadderCodelistVO"/>
	<typeAlias  alias="LadderCommentVO" type="egovframework.ezEKP.ezLadder.vo.LadderCommentVO"/>
	<typeAlias  alias="LadderLineVO" type="egovframework.ezEKP.ezLadder.vo.LadderLineVO"/>
	<typeAlias  alias="LadderOrderVO" type="egovframework.ezEKP.ezLadder.vo.LadderOrderVO"/>
