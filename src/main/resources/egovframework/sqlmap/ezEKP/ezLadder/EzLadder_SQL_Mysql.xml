		<result property="userName" column="USERNAME" columnIndex="5"/>
		<result property="userName2" column="USERNAME2" columnIndex="6"/>
	</resultMap>
	
	<resultMap id="LadderBm" class="LadderBmVO">
		<result property="tenant_id" column="TENANT_ID" columnIndex="1"/>
		<result property="ladderBmId" column="LADDERBMID" columnIndex="2"/>
		<result property="bmName" column="BMNAME" columnIndex="3"/>
		<result property="userId" column="USERID" columnIndex="4"/>
		<result property="regdate" column="REGDATE" columnIndex="5"/>
	</resultMap>
	
	<resultMap id="LadderCodelist" class="LadderCodelistVO">
		<result property="tenant_id" column="TENANT_ID" columnIndex="1"/>
		<result property="code" column="CODE" columnIndex="2"/>
		<result property="language" column="LANGUAGE" columnIndex="3"/>
		<result property="name" column="NAME" columnIndex="4"/>
		<result property="description" column="DESCRIPTION" columnIndex="5"/>
	</resultMap>
	
	<resultMap id="LadderComment" class="LadderCommentVO">
		<result property="tenant_id" column="TENANT_ID" columnIndex="1"/>
		<result property="id" column="ID" columnIndex="2"/>
		<result property="comment" column="COMMENT" columnIndex="3"/>
		<result property="userId" column="USERID" columnIndex="4"/>
		<result property="userName" column="USERNAME" columnIndex="5"/>
		<result property="userName2" column="USERNAME2" columnIndex="6"/>
		<result property="writeDate" column="WRITEDATE" columnIndex="7"/>
	</resultMap>
	
	<resultMap id="LadderLine" class="LadderLineVO">
		<result property="tenant_id" column="TENANT_ID" columnIndex="1"/>
		<result property="userId" column="USERID" columnIndex="2"/>
		<result property="userName" column="USERNAME" columnIndex="3"/>
		<result property="userName2" column="USERNAME2" columnIndex="4"/>
		<result property="item" column="ITEM" columnIndex="5"/>
		<result property="ladderOrder" column="LADDERORDER" columnIndex="6"/>
		<result property="resultUserId" column="RESULTUSERID" columnIndex="7"/>
		<result property="resultUserName" column="RESULTUSERNAME" columnIndex="8"/>
		<result property="resultUserName2" column="RESULTUSERNAME2" columnIndex="9"/>
		<result property="ladderId" column="LADDERID" columnIndex="10"/>
		<result property="writerId" column="WRITERID" columnIndex="11"/>
	</resultMap>
	
	<resultMap id="LadderOrder" class="LadderOrderVO">
		<result property="tenant_id" column="TENANT_ID" columnIndex="1"/>
		<result property="id" column="ID" columnIndex="2"/>
		<result property="ladderId" column="LADDERID" columnIndex="3"/>
		<result property="changeLadderId" column="CHANGELADDERID" columnIndex="4"/>
		<result property="userId" column="USERID" columnIndex="5"/>
	</resultMap>
	
	<resultMap id="Ladder" class="LadderVO">
		<result property="tenant_id" column="TENANT_ID" columnIndex="1"/>
		<result property="ladderId" column="LADDERID" columnIndex="2"/>
		<result property="title" column="TITLE" columnIndex="3"/>
		<result property="type" column="TYPE" columnIndex="4"/>
		<result property="status" column="STATUS" columnIndex="5"/>
		<result property="secretFlag" column="SECRETFLAG" columnIndex="6"/>
		<result property="writerId" column="WRITERID" columnIndex="7"/>
		<result property="writerName" column="WRITERNAME" columnIndex="8"/>
		<result property="writerName2" column="WRITERNAME2" columnIndex="9"/>
		<result property="deptName" column="DEPTNAME" columnIndex="10"/>
		<result property="deptName2" column="DEPTNAME2" columnIndex="11"/>
		<result property="lineCnt" column="LINECNT" columnIndex="12"/>
		<result property="lineArray" column="LINEARRAY" columnIndex="13"/>
		<result property="deleteFlag" column="DELETEFLAG" columnIndex="14"/>
		<result property="writeDate" column="WRITEDATE" columnIndex="15"/>
		<result property="startDate" column="STARTDATE" columnIndex="16"/>
		<result property="deleteDate" column="DELETEDATE" columnIndex="17"/>
	</resultMap>
	
	<select id="EzLadderDAO.getLadderList" resultClass="LadderVO">
		<![CDATA[
			SELECT TYPE, TITLE, WRITERNAME, WRITEDATE, STATUS, SECRETFLAG, DELETEFLAG
			FROM TBL_LADDER
			WHERE SECRETFLAG = 0 or LADDERID = ANY(
										SELECT TBL_LADDER.LADDERID 
                                        FROM TBL_LADDER 
                                        JOIN TBL_LADDER_LINE ON TBL_LADDER.LADDERID = TBL_LADDER_LINE.LADDERID
										WHERE TBL_LADDER_LINE.USERID = #userId#) 
			ORDER BY LADDERID DESC;
		]]>
	</select>
	
 	<insert id="EzLadderDAO.insertLadderSet" parameterClass="LadderVO">
		INSERT INTO TBL_LADDER 
			(TENANT_ID, TITLE, TYPE, SECRETFLAG, WRITERID, WRITERNAME, WRITERNAME2, DEPTNAME, DEPTNAME2, LINECNT, WRITEDATE)
		VALUES 
			(#tenant_id#, #title#, #type#, #secretFlag#, #writerId#, #writerName#, #writerName2#, #deptName#, #deptName2#, #lineCnt#, NOW())
	</insert>
	
	<insert id="EzLadderDAO.insertLadderLine" parameterClass="LadderLineVO">
		INSERT INTO 
			TBL_LADDER_LINE (TENANT_ID, LADDERID, USERID, USERNAME, USERNAME2, ITEM, LADDERORDER)
		VALUES
			(#tenant_id#, #ladderId#, #userId#, #userName#, #userName2#, #item#, #ladderOrder#)
		<selectKey keyProperty="ladderId" resultClass="Integer">
			SELECT 
				MAX(LADDERID) 
			FROM 
				TBL_LADDER 
			WHERE 
				WRITERID = #writerId#
		</selectKey>
	</insert> 
</sqlMap>