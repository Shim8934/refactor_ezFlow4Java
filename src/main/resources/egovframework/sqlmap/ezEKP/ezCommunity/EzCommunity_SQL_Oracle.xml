	<select id="EzCommunityDAO.getBoardTreeGet2"				parameterClass="String"		resultMap="CategoryValue">
		<![CDATA[
			SELECT 
				BOARDID || N';' AS BOARDID 
			FROM 
				EZCOMMUNITY.TBL_BOARD_BOARDMANAGE 
			WHERE 
				ACCESS_ = 0 
			AND 
				ACCESSID = #pUserID#
		]]>		
	</select>
	
	<select id="EzCommunityDAO.getCategoryValueA"	resultMap="CategoryValue">
		<![CDATA[
			SELECT 
				*
			FROM
				EZCOMMUNITY.C_CATEGORY
			WHERE
				C_CAT=N'a'
			ORDER BY
				C_CODE,
				C_ORDER
		]]>		
	</select>
	
