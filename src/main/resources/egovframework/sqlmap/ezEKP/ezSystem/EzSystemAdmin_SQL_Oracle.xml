<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd" >
<sqlMap namespace="ezSystemAdmin">

	<typeAlias alias="SysParamVO" type="egovframework.ezEKP.ezSystem.vo.SysParamVO"/>
	<typeAlias alias="ConnectionInfoVO" type="egovframework.ezEKP.ezSystem.vo.ConnectionInfoVO"/>
	
	
	<select id="EzSystemAdminDAO.getSysParam" parameterClass="Integer" resultClass="SysParamVO">
		<![CDATA[
			SELECT 
				PROPERTY_NAME name,
				PROPERTY_VALUE value
			FROM 
				TBL_TENANT_CONFIG
			WHERE 
				TENANT_ID=#TENANTID#
		]]>
	</select>
	
	<update id="EzSystemAdminDAO.updateSysParam" parameterClass="SysParamVO">
	<![CDATA[
		UPDATE 
			TBL_TENANT_CONFIG 
		SET 
			PROPERTY_VALUE=#value# 
		WHERE 
			PROPERTY_NAME=#name#
		AND
			TENANT_ID=#tenantID#
	]]>
	</update>

	<sql id="EzSystemAdminDAO.searchQuery">
		<isNotEmpty property="search_keycode" prepend="and">
			<isNotEmpty property="search_keyword" >
				<isEqual property="lang" compareValue="primary" >
					<isEqual property="search_keycode" compareValue="1">
						USERNM LIKE '%'||#search_keyword#||'%'
					</isEqual>
					<isEqual property="search_keycode" compareValue="2">
						DEPTNM LIKE '%'||#search_keyword#||'%'
					</isEqual>
				</isEqual>
				<isNotEqual property="lang" compareValue="primary">
					<isEqual property="search_keycode" compareValue="1">
						USERNM2 LIKE '%'||#search_keyword#||'%'
					</isEqual>
					<isEqual property="search_keycode" compareValue="2">
						DEPTNM2 LIKE '%'||#search_keyword#||'%'
					</isEqual>
				</isNotEqual>
				<isEqual property="search_keycode" compareValue="3">
					CONNECTIP LIKE '%'||#search_keyword#||'%'
				</isEqual>
				<isEqual property="search_keycode" compareValue="4">
					CONNECTBROWSER LIKE '%'||#search_keyword#||'%'
				</isEqual>
				<isEqual property="search_keycode" compareValue="5">
					CONNECTOS LIKE '%'||#search_keyword#||'%'
				</isEqual>
			</isNotEmpty>
		</isNotEmpty>
		<isNotEmpty property="startDate" prepend="and">
			<![CDATA[
			TO_CHAR((CONNECTTIME + #offset# / (24 * 60)),'YYYY-MM-DD') >= #startDate# 
			]]>
		</isNotEmpty>
		<isNotEmpty property="endDate" prepend="and">
			<![CDATA[
			TO_CHAR((CONNECTTIME + #offset# / (24 * 60)),'YYYY-MM-DD') <= #endDate#
			]]>
		</isNotEmpty>
	</sql>
	
	<select id="EzSystemAdminDAO.getLoginHist" parameterClass="map" resultClass="ConnectionInfoVO">
		 	SELECT
		 	 	X.rnum, 
			    TO_CHAR((X.CONNECTTIME + #offset# / (24 * 60)),'YYYY-MM-DD HH24:MI:SS') AS CONNECTTIME,
	            X."SEQUENCE",
	            X.USERNM,
	            X.USERNM2,
	            X.DEPTNM,
	            X.DEPTNM2,
	            X.CONNECTIP,
	            X.CONNECTBROWSER,
	            X.CONNECTOS
            FROM (
				SELECT 
			    	ROWNUM AS rnum,
				    A.CONNECTTIME, 
					A."SEQUENCE",
					A.USERNM,
					A.USERNM2,
					A.DEPTNM,
					A.DEPTNM2,
					A.CONNECTIP,
					A.CONNECTBROWSER,
					A.CONNECTOS
				FROM 
					(
					SELECT  
					    C.CONNECTTIME,
						C."SEQUENCE",
						C.USERNM,
						C.USERNM2,
						C.DEPTNM,
						C.DEPTNM2,
						C.CONNECTIP,
						C.CONNECTBROWSER,
						C.CONNECTOS
					FROM 
						TBL_CONNECTION_INFO C INNER JOIN TBL_USERLOCALINFO U
					ON 
						C.USERID = U.USERID
					WHERE 
						C.TENANT_ID=#v_tenantID# AND U.TENANT_ID=#v_tenantID#
						<include refid="EzSystemAdminDAO.searchQuery"/>
				    ORDER BY 
				    	C."SEQUENCE" DESC
					) A
		<isNotEqual property="v_start" compareValue="-1">
			<![CDATA[
            	WHERE ROWNUM <= (#pageCount# + #v_start#)
			]]>
		</isNotEqual> 
            	) X
		<isNotEqual property="v_start" compareValue="-1">
			<![CDATA[
         	WHERE X.rnum >= (#v_start# + 1)
			]]>
		</isNotEqual>
	</select>
	
	<select id="EzSystemAdminDAO.getLoginHistCount" parameterClass="map" resultClass="int">
		SELECT 	COUNT(SEQUENCE) 
		FROM   	TBL_CONNECTION_INFO C INNER JOIN TBL_USERLOCALINFO U
		ON 		C.USERID = U.USERID
		WHERE	C.TENANT_ID = #v_tenantID# AND U.TENANT_ID = #v_tenantID# 
		<include refid="EzSystemAdminDAO.searchQuery"/>
	</select>
	
	<delete id="EzSystemAdminDAO.deleteLoginHist" parameterClass="Map">
		<![CDATA[
			DELETE FROM
				TBL_CONNECTION_INFO
            WHERE
            	TENANT_ID = #v_TENANT_ID#	
            AND
            	CONNECTTIME < sysdate - #v_KEEP_LOG_PERIOD#
		]]>
	</delete>
	
	
</sqlMap>