	<select id="EzQuestionDAO.getItemSeq" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT 
				NVL(max(item_no),-1) as maxno
			FROM 
				ezQuestion.TBLITEMSEQ 
			WHERE  
				brd_id = #brdId#
		]]>		
	</select>
	
	<select id="EzQuestionDAO.getUserResponseCnt" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT 
				COUNT(*) as CNT
			FROM
				EZQUESTION.TBLPOLL_RESPONSE
			WHERE
				brd_id	=	#v_pstrBrdID#
			AND 
				item_no	=	#v_pItemNo#
			AND 
				responseuser_id	=	#v_puserID#
		]]>		
	</select>
	
	<select id="EzQuestionDAO.getUserIdAdmin" parameterClass="Integer" resultClass="String">
		<![CDATA[
			SELECT
				USER_ID 
			FROM
				EZQUESTION.TBLBRDMNG 
			WHERE
				brd_id	=	#brdID#
			AND 
				admin_fg = N'1'
		]]>
	</select>
	
	<select id="EzQuestionDAO.getResponseDateCnt" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT
				COUNT(response_date)  
        	FROM
        		EZQUESTION.TBLPOLL_RESPONSE 
       		WHERE
       			brd_id	=	#v_pstrBrdID#
            AND 
            	item_no	=	#v_pItemNo#
       	   	AND 
       	   		responseuser_id	=	#v_pUserID#
		]]>
	</select>
	
	<select id="EzQuestionDAO.resCount" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT
				res_cnt 
      		FROM
      			EZQUESTION.TBLPOLL_ITEM 
      		WHERE
      			brd_id	=	#v_pstrBrdID#
      		AND
      			item_no	=	#v_pItemNo#
		]]>
	</select>
	
	<select id="EzQuestionDAO.getReadDateItem" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT
				COUNT(Read_Date)  
        	FROM
        		EZQUESTION.TBLPOLL_ITEMREAD 
       		WHERE
       			brd_id	=	#v_pstrBrdID#
            AND
            	item_no	=	#v_pItemNo#
            AND
            	user_id	=	#v_pUserID#
		
		]]>
	</select>
	
	<insert id="EzQuestionDAO.insertItemSeq" parameterClass="String">
		<![CDATA[
			INSERT INTO ezQuestion.TBLITEMSEQ 
			VALUES (#v_pstrBrdID#, N'1') 
		]]>
	</insert>
	
	 <update id="EzQuestionDAO.updateItemSeq" parameterClass="Map">
		<![CDATA[
			UPDATE ezQuestion.TBLITEMSEQ
			SET item_no = #v_pItemNo#
			WHERE brd_id = #v_pstrBrdID#  
		]]>
	</update>
	
