	<procedure id="EzQuestionDAO.getQstListCnt" parameterClass="Map" resultClass="Integer">
		{CALL EZQUESTION.EZSP_QSTLISTCNT(#v_PSTRBRDID#, #v_PUSERID#, #v_PTITLE#, #v_PRANGE#, #v_PSDATE#, #v_PEDATE#, #v_PLANG#, #v_pCount,javaType=java.lang.Integer,jdbcType=DECIMAL,mode=OUT#)}
	</procedure>
	
	<procedure id="EzQuestionDAO.getQstList" parameterClass="Map" resultMap="qstList">
		{CALL EZQUESTION.EZSP_QSTLIST(#v_PSTRBRDID#, #v_PUSERID#, #v_PTOTALCNT#, #v_PPAGESIZE#, #v_PTITLE#, #v_PRANGE#, #v_PSDATE#, #v_PEDATE#, #v_PLANG#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>

	<procedure id="EzQuestionDAO.getUserPollItem" parameterClass="Map" resultMap="userPollItem">
		{CALL EZQUESTION.EZSP_GETUSERPOLLITEM(#v_pstrBrdID#, #v_pItemNo#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	
	<procedure id="EzQuestionDAO.getUserPermission" parameterClass="Map" resultMap="userPermission">
		{CALL EZQUESTION.EZSP_GETUSERPERMISSION(#v_pstrBrdID#, #v_pItemNo#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
	</procedure>
	<!-- 수정필요 -->
	<select id="EzQuestionDAO.getUserResponseCnt" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT 
				COUNT(*) as CNT
			FROM
				EZQUESTION.TBLPOLL_RESPONSE
			WHERE
				brd_id = #v_pstrBrdID#
			AND 
				item_no = #v_pItemNo#
			AND 
				responseuser_id = #v_puserID#
		]]>		
	</select>
	
	<select id="EzQuestionDAO.getUserIdAdmin" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT
				USER_ID 
			FROM
				EZQUESTION.TBLBRDMNG 
			WHERE
				brd_id = #brdID#
			AND 
				admin_fg = N'1'
		]]>
	</select>
	
	<procedure id="EzQuestionDAO.getItemNoCnt" parameterClass="Map" resultClass="Integer">
