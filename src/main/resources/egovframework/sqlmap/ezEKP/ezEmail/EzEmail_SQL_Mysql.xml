	<insert id="EzEmailDAO.setBigAttachCountInfo" parameterClass="Map">
			INSERT INTO JMOCHA_BIGATTACH_DOWN_LIMIT
				(file_id, download_count, limit_count, tenant_id)
			VALUES
				<iterate property="fileIdArr" conjunction=",">
				(#fileIdArr[]#, 0, #limitCount#, #tenantId#)
				</iterate>
	</insert>
	
	<select id="EzEmailDAO.checkBigAttachDownloadCount" parameterClass="Map" resultClass="String">
		<![CDATA[
			SELECT 
				LIMIT_COUNT
	        FROM 
	        	JMOCHA_BIGATTACH_DOWN_LIMIT
	       	WHERE
	       		FILE_ID = #fileId#
	       	AND
	       		TENANT_ID = #tenantId#
	       	AND
	       		DOWNLOAD_COUNT >= LIMIT_COUNT
	       	AND
	       		LIMIT_COUNT > 0
       	]]>
	</select>
	
	<update id="EzEmailDAO.updateBigAttachDownloadCount" parameterClass="Map">
		<![CDATA[
			UPDATE
				JMOCHA_BIGATTACH_DOWN_LIMIT
			SET
     			DOWNLOAD_COUNT = DOWNLOAD_COUNT + 1
     		WHERE
      			FILE_ID = #fileId#
      		AND 
            	TENANT_ID = #tenantId#
       	]]>
	</update>
	
	<delete id="EzEmailDAO.deleteBigAttachCountInfo" parameterClass="Map">
			DELETE FROM JMOCHA_BIGATTACH_DOWN_LIMIT
     		WHERE FILE_ID IN (<iterate property="fileIdArr" conjunction=",">#fileIdArr[]#</iterate>)
      		AND TENANT_ID = #tenantId#
	</delete>
	
	<insert id="EzEmailDAO.setMailboxProgress" parameterClass="Map">
		<![CDATA[
			INSERT INTO jmocha_mailbox_progress 
				(USER_KEY, TENANT_ID, USER_ID, ACT, PERCENT)
			VALUES 
			(#userKey#, #tenantId#, #userId#, #action#, #percent#)
		]]>
	</insert>
	
	<update id="EzEmailDAO.updateMailboxProgress" parameterClass="Map">
		<![CDATA[
			UPDATE 
				JMOCHA_MAILBOX_PROGRESS 
			SET 
				PERCENT = #percent#, UPDATEDT = SYSDATE()
			WHERE 
				USER_KEY = #userKey#
		]]>
	</update>

	<update id="EzEmailDAO.updateMailboxProgressState" parameterClass="Map">
		UPDATE
			JMOCHA_MAILBOX_PROGRESS
		SET
			STATE = #state#, STATE_DESCRIPTION = #stateDescription#, UPDATEDT = SYSDATE()
		WHERE
			USER_KEY = #userKey#
	</update>

	<select id="EzEmailDAO.getMailboxProgress" parameterClass="Map" resultClass="egovframework.ezEKP.ezEmail.vo.MailboxProgressVO">
		<![CDATA[
			SELECT
			PERCENT AS PROGRESS,
			STATE,
			STATE_DESCRIPTION AS STATEDESCRIPTION
			FROM 
				JMOCHA_MAILBOX_PROGRESS 
			WHERE 
				USER_KEY = #userKey#
		]]>
	</select>
	
	<delete id="EzEmailDAO.deleteMailboxProgress" parameterClass="Map">
		<![CDATA[
			DELETE FROM 
				JMOCHA_MAILBOX_PROGRESS 
			WHERE 
				USER_KEY = #userKey#
		]]>
	</delete>

	<select id="EzEmailDAO.checkApprMailApprover" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT
				COUNT(USER_ID)
			FROM
				JMOCHA_APPR_USER
			WHERE
				USER_ID = #cn#
			AND
				USER_TYPE = 'approver'
			AND
				COMPANY_ID = #companyId#
			AND
				TENANT_ID = #tenantId#
		]]>
	</select>
	
