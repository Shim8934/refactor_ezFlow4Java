			VALUES (#v_USERID#, #v_POP3SERVER#, #v_POP3PORTNO#, #v_POP3USERID#, #v_POP3PW#, #v_SAVETO#, #v_DELETEYN#, #v_POP3SSLYN#, #v_SAVETOFOLDER#)
