	<select id="EzEmailDAO.getOrphanedMailBlobList" resultMap="mailBlob">
		<![CDATA[
			SELECT MAIL_BLOB_ID, a.MAILBOX_ID, a.MAIL_UID
			FROM JAMES_MAIL_BLOB a
			LEFT OUTER JOIN JAMES_MAIL b
			ON a.MAILBOX_ID = b.MAILBOX_ID
			AND a.MAIL_UID = b.MAIL_UID 
			WHERE b.MAILBOX_ID IS NULL
       	]]>
	</select>
	
	<delete id="EzEmailDAO.deleteOrphanedMailBlob" parameterClass="MailBlobVO">
		<![CDATA[
			DELETE FROM JAMES_MAIL_BLOB 
			WHERE MAIL_BLOB_ID = #mailBlobId#
       	]]>
	</delete>

