	<select id="EzCommonDAO.selectUserGetLang" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT 
				lang
			FROM 
				EZCOMMON.TBLUSERLOCALINFO
			WHERE
				userID = #userID#
		]]>
	</select>
	
	<select id="EzCommonDAO.selectUserGetTimeZone" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT 
				timeZone
			FROM 
				EZCOMMON.TBLUSERLOCALINFO
			WHERE
				userID = #userID#
		]]>
	</select>
	
	<select id="EzCommonDAO.getTenantIdByDomainName" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT
				tenant_id
			FROM
				EZHRMASTER.TBLTENANT_CONFIG
			WHERE
				property_name = 'DomainName'
			AND
				property_value = #DOMAIN_NAME#
		]]>
	</select>
	
	<select id="EzCommonDAO.getTenantServerNameList" resultClass="TenantServerNameVO">
		<![CDATA[
			SELECT 
				tenant_id tenantId,
				server_name serverName 
			FROM 
				EZHRMASTER.TBLTENANT_SERVERNAME
		]]>
	</select>
	
	<select id="EzCommonDAO.getTenantList" resultClass="TenantVO">
		<![CDATA[
			SELECT 
				tenant_id tenantId,
				tenant_name tenantName 
			FROM 
				EZHRMASTER.TBLTENANT
		]]>
	</select>
	
	<select id="EzCommonDAO.getTenantConfig" parameterClass="map" resultClass="String">
		<![CDATA[
			SELECT 
				property_value
			FROM 
				EZHRMASTER.TBLTENANT_CONFIG
			WHERE
				tenant_id = #tenantID#
			AND
				UPPER(property_name) = #property#
		]]>
	</select>
	
	<select id="EzCommonDAO.getTenantConfigs" parameterClass="Integer" resultClass="HashMap">
		<![CDATA[
			SELECT
				property_name,
				property_value
			FROM
				EZHRMASTER.TBLTENANT_CONFIG
			WHERE
				tenant_id = #tenantID#
		]]>
	</select>
	
	<insert id="EzCommonDAO.insertTblUserLocalInfo" parameterClass="Map">
		<![CDATA[
			INSERT INTO EZCOMMON.TBLUSERLOCALINFO (
				USERID,TIMEZONE,LANG
			)
			VALUES (
				#userID#,#timeZone#,#lang#
			)
		]]>
	</insert>
	
	<delete id="EzCommonDAO.deleteUserLLocalInfo" parameterClass="Map">
		<![CDATA[
			DELETE EZCOMMON.TBLUSERLOCALINFO
			WHERE userID = #userID# 
		]]>
	</delete>
	
	
</sqlMap>