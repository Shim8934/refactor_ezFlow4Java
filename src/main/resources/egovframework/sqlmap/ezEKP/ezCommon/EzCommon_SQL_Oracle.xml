	<select id="EzCommonDAO.getApprovPWD" parameterClass="userInfo" resultClass="ApprovPWDVO">
		<![CDATA[
			SELECT 
				* 
		    FROM 
		    	TBPWDINFO 
		    WHERE  
		    	TENANT_ID = #tenantId#
		    AND
		    	USERID = #id#
		]]>
	</select>
	
