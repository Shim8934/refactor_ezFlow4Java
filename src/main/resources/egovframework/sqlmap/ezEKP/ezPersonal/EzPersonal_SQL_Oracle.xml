	<!-- <procedure id="EzPersonalDAO.getPollResultOrderResult" parameterClass="Integer"  resultClass="PersonalLightPollVO" >
		<![CDATA[
			{CALL EZPERSONAL.EZSP_GETPOLLRESULTORDERRESULT(#v_pItemSeq#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>
	</procedure> -->
	
	<select id="EzPersonalDAO.getPollResultOrderResult" parameterClass="Map"  resultClass="PersonalLightPollVO">
		<![CDATA[
			SELECT
				RESULT ,
             	COUNT(RESULT)  COUNT  
        	FROM
        		EZPERSONAL.TBLLIGHTPOLLRESULT 
       		WHERE
       			ITEMSEQ = #v_pItemSeq#
       		AND
       			TENANT_ID = #tenantID#	
        	GROUP BY
        		RESULT
        	ORDER BY
        		COUNT DESC,
                RESULT ASC
		]]>
	</select>
	
	<!-- <procedure id="EzPersonalDAO.getPollInfo" parameterClass="Integer"  resultClass="PersonalLightPollVO" >
		<![CDATA[
