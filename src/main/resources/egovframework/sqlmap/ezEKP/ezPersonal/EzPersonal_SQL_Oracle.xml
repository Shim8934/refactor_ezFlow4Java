	<!-- <procedure id="EzPersonalDAO.getPollCount" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			{CALL EZPERSONAL.EZSP_GETPOLLCOUNT(#v_pCompanyID#, #v_pMode#, #v_pCount,javaType=java.lang.Integer,jdbcType=DECIMAL,mode=OUT#)}
		]]>
	</procedure>	 -->
	
	<select id="EzPersonalDAO.getPollCount" parameterClass="Map" resultClass="Integer">
		<isEqual property="v_pMode" compareValue="A">
			<![CDATA[
				SELECT
					COUNT(ITEMSEQ)
           		FROM
           			EZPERSONAL.TBLLIGHTPOLL 
          		WHERE
          			COMPANYID = #v_pCompanyID#
          		AND
          			TENANT_ID = #tenantID#	
			]]>
		</isEqual>
		<isNotEqual property="v_pMode" compareValue="A">
			<![CDATA[
				SELECT
					COUNT(ITEMSEQ)
           		FROM
           			EZPERSONAL.TBLLIGHTPOLL 
          		WHERE
          			( COMPANYID = #v_pCompanyID#
                OR
                	COMPANYID = 'Top' )
                AND
                	TENANT_ID = #tenantID#	
			]]>
		</isNotEqual>
	</select>
	
	<!-- <procedure id="EzPersonalDAO.getPollListUser" parameterClass="Map"  resultClass="PersonalLightPollVO"  remapResults="true">
		<![CDATA[
			{CALL EZPERSONAL.EZSP_GETPOLLLISTUSER(#v_pCompanyID#, #v_pTotal#, #v_pCount#, #v_pStart#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>
	</procedure> -->
	
	<select id="EzPersonalDAO.getPollListUser" parameterClass="Map"  resultClass="PersonalLightPollVO">
		<isEqual property="v_pStart" compareValue="0">
			<![CDATA[
				SELECT
					* 
           		FROM
           			( 	SELECT
           				ITEMSEQ ,
                        POLLTITLE ,
                        POLLTITLE2 ,
                        STARTDATE ,
                        NVL(EndDate, to_date('1900-01-01', 'yyyy-MM-dd HH24:MI:SS')) EndDate  
           			FROM
           				EZPERSONAL.TBLLIGHTPOLL 
          			WHERE
          				( COMPANYID = #v_pCompanyID#
                   	OR
                   		COMPANYID = 'Top' )
                   	AND
                   		TENANT_ID = #tenantID#
           			ORDER BY
           				ITEMSEQ DESC )
           		WHERE
           			ROWNUM <= #v_pCount#
			]]>
		</isEqual>
		<isNotEqual property="v_pStart" compareValue="0">
			<![CDATA[
				SELECT
					* 
           		FROM
           			( SELECT
           				ITEMSEQ ,
                        POLLTITLE ,
                        POLLTITLE2 ,
                        STARTDATE ,
                        ENDDATE 
           			FROM
           				( 	SELECT
           						* 
                    		FROM
                    			( SELECT
                    				ITEMSEQ ,
                                  	POLLTITLE ,
                                  	POLLTITLE2 ,
                                  	STARTDATE ,
                                  	NVL(ENDDATE, to_date('1900-01-01', 'yyyy-MM-dd HH24:MI:SS')) EndDate  
                  				FROM
                  					EZPERSONAL.TBLLIGHTPOLL 
                   				WHERE
                   					( (	COMPANYID = #v_pCompanyID#
                            		OR
                            			COMPANYID = 'Top' )
                            		AND
                            			TENANT_ID = #tenantID#	
                    			ORDER BY
                    				ITEMSEQ ASC )
                    		WHERE
                    			ROWNUM <= #v_pTotal# - #v_pStart# ) EZPERSONAL.TEMPTBLLIGHTPOLL
           					ORDER BY
           						ITEMSEQ DESC )
           		WHERE
           			ROWNUM <= #v_pCount#
			]]>
		</isNotEqual>
	</select>
	
	<!-- <procedure id="EzPersonalDAO.getCurrentPoll" parameterClass="Map"  resultClass="PersonalLightPollVO" >
		<![CDATA[
			{CALL EZPERSONAL.EZSP_GETCURRENTPOLL(#v_pUserID#, #v_pCompanyID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>
	</procedure> -->
	
	<select id="EzPersonalDAO.getCurrentPoll" parameterClass="Map"  resultClass="PersonalLightPollVO">
		<![CDATA[
			SELECT
				* 
        	FROM
        		( SELECT
        			 A.ITEMSEQ ,
                     STARTDATE ,
                     POLLSELECTIONCOUNT ,
                     POLLTITLE ,
                     POLLTITLE2 ,
                     ANSWER1 ,
                     ANSWER2 ,
                     ANSWER3 ,
                     ANSWER4 ,
                     ANSWER5 ,
                     ANSWER6 ,
                     ANSWER7 ,
                     ANSWER8 ,
                     ANSWER9 ,
                     ANSWER10 ,
                     NVL(B.RESULT, 0) Result  
        		FROM
        			EZPERSONAL.TBLLIGHTPOLL A
               	LEFT JOIN
               		EZPERSONAL.TBLLIGHTPOLLRESULT B
               	ON
               		A.ITEMSEQ = B.ITEMSEQ
               	AND
               		USERID = #v_pUserID#
       			WHERE
       				( 	COMPANYID = #v_pCompanyID#
                	OR
                		COMPANYID = 'Top' )
                	AND
                		STARTDATE < to_date(#nowDate#, 'YYYY-MM-DD HH24:MI:SS')
                	AND
                		ENDDATE IS NULL
                	AND
                		A.TENANT_ID = #tenantID#	
        			ORDER BY
        				A.ITEMSEQ DESC )
        		WHERE
        			ROWNUM <= 1
		]]>
	</select>
	
