		<![CDATA[
			{CALL EZPERSONAL.EZSP_GETPOPUPLISTUSER(#v_pCompanyID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>
	</procedure> -->
	
	<select id="EzPersonalDAO.getPopUpListUser" parameterClass="Map"  resultClass="PersonalGetPopUpListUserVO">
		<![CDATA[
			SELECT
				ITEMSEQ ,
             	WIDTH ,
             	HEIGHT ,
             	POSITION 
        	FROM
        		EZPERSONAL.TBLPOPUP 
       		WHERE
       			( 	COMPANYID = 'Top'
                OR
                	COMPANYID = #v_pCompanyID# )
            AND
            	STARTDATE <= to_date(#nowDate#, 'YYYY-MM-DD HH24:MI:SS')
            AND
            	ENDDATE >= to_date(#nowDate#, 'YYYY-MM-DD HH24:MI:SS')
            AND
            	TENANT_ID = #tenantID#	
		]]>
	</select>
	
