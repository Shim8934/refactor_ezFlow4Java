			{CALL EZPERSONAL.EZSP_GETSLIDERLIST(#v_COMPANYID#, #v_MODE#, #v_SLIDERID#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>
	</procedure> -->
	
	<select id="EzPersonalDAO.getSliderList" parameterClass="Map"  resultClass="PersonalSliderImageVO">
		<isEqual property="v_MODE" compareValue="ADMIN">
			<isEmpty property="v_SLIDERID">
				<![CDATA[
					SELECT
						SLIDERID ,
                   		SLIDERNAME ,
                   		SLIDERNAME2 ,
                   		IMAGEPATH ,
                   		REGUSERID ,
                   		REGDATE ,
                   		SN ,
                   		ISUSE 
              		FROM
              			EZPERSONAL.TBL_SLIDERIMAGE 
             		WHERE
             			COMPANYID = #v_COMPANYID#
             		AND
             			TENANT_ID = #tenantID#	
              		ORDER BY
              			SN
				]]>
			</isEmpty>
			<isNotEmpty property="v_SLIDERID">
				<![CDATA[
					SELECT
						SLIDERID ,
                   		SLIDERNAME ,
                   		SLIDERNAME2 ,
                   		IMAGEPATH ,
                   		REGUSERID ,
                   		REGDATE ,
                   		SN ,
                   		ISUSE 
              		FROM
              			EZPERSONAL.TBL_SLIDERIMAGE 
             		WHERE
             			COMPANYID = #v_COMPANYID#
                    AND
                    	SLIDERID = #v_SLIDERID#
                    AND
                    	TENANT_ID = #tenantID#	
              		ORDER BY
              			SN
				]]>
			</isNotEmpty>
		</isEqual>
		<isNotEqual property="v_MODE" compareValue="ADMIN">
			<![CDATA[
				SELECT
					SLIDERID ,
                	SLIDERNAME ,
                	SLIDERNAME2 ,
                	IMAGEPATH ,
                	REGUSERID ,
                	REGDATE ,
                	SN ,
                	ISUSE 
           		FROM
           			EZPERSONAL.TBL_SLIDERIMAGE 
          		WHERE
          			COMPANYID = #v_COMPANYID#
                AND
                	ISUSE = 1
                AND
                	TENANT_ID = #tenantID#	
           		ORDER BY
           			SN
			]]>
		</isNotEqual>
	</select>
		
