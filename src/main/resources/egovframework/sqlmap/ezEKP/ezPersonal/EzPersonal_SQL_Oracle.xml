	<select id="EzPersonalDAO.getQuickLinkMenu" parameterClass="Map"  resultClass="PersonalGetQuickLinkMenuVO">
		<![CDATA[
			SELECT
				A.QUICKLINKID QuickLinkID  ,
             	QUICKLINKNAME ,
             	QUICKLINKNAME2 ,
             	QUICKLINKNAME3 ,
             	QUICKLINKNAME4 ,
             	LINKTYPE ,
             	LINKTYPEURL ,
             	URL ,
             	REGUSERID ,
             	VIEW_FLAG ,
             	SIZE_ 
        	FROM
        		EZPERSONAL.TBLQUICKLINK A
            JOIN
            	EZPERSONAL.TBLQUICKLINK_ACL B
            ON
            	A.QUICKLINKID = B.QUICKLINKID
       		WHERE
       			( ACCESSID = #v_ACCESSID# )
       		AND
       			A.TENANT_ID = #tenantID#	
		]]>
