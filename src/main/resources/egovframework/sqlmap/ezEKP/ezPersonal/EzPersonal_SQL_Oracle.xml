	<!-- <procedure id="EzPersonalDAO.getUserWebPart" parameterClass="Map"  resultClass="PersonalGetWebPartVO" >
		<![CDATA[
			{CALL EZPERSONAL.EZSP_GETUSERWEBPART(#v_pUserID#, #v_pCompanyID#, #v_pACL#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>
	</procedure> -->
	
	<select id="EzPersonalDAO.getUserWebPart_S1" parameterClass="Map"  resultClass="String">
		<![CDATA[
			SELECT
				1
			FROM
				DUAL
    		WHERE
    			NOT EXISTS (	SELECT
    									ITEMSEQ
    							 	FROM
    							 		EZPERSONAL.TBLUSERWEBPART
    							 	WHERE
    							 		USERID = #v_PUserID#
    							 	AND
    							 		TENANT_ID = #tenantID#	)
		]]>
	</select>
	
	<select id="EzPersonalDAO.getUserWebPart_S2" parameterClass="Map"  resultClass="PersonalGetWebPartVO">
		<![CDATA[
			SELECT
				NAME, URL, DEFAULTPOSITION AS POSITION, DEFAULTPRIORITY, ID
			FROM
				EZPERSONAL.TBLWEBPARTITEM
			JOIN
				EZPERSONAL.TBLWEBPARTITEMACL
			ON
				ID=ItemID
			WHERE
				(COMPANYID='S907000'  OR COMPANYID='Top')
			AND
				DEFAULTUSE=1 
			AND
				ACCESSID IN ('gisa1','top','Top','S907000','RAB1')
			ORDER BY
				DEFAULTPOSITION, DEFAULTPRIORITY
		]]>
	</select>
	
	<select id="EzPersonalDAO.getUserWebPart_S3" parameterClass="Map"  resultClass="PersonalGetWebPartVO">
		<![CDATA[
			SELECT
				B.NAME, B.URL, A.ITEMPOSITION AS POSITION, A.ITEMSEQ,  B.ID 
			FROM
				EZPERSONAL.TBLUSERWEBPART A 
			JOIN
				EZPERSONAL.TBLWEBPARTITEM B
			ON
				A.ITEMID=B.ID
			JOIN
				EZPERSONAL.TBLWEBPARTITEMACL C
			ON
				C.ITEMID=B.ID
			WHERE
				A.USERID='gisa1'
			AND
				C.ACCESSID IN ('gisa1','top','Top','S907000','RAB1')
			ORDER BY
				A.ITEMPOSITION, A.ITEMSEQ
		]]>
	</select>
	
	<!-- <procedure id="EzPersonalDAO.getEmpOfMonth" parameterClass="String"  resultClass="PersonalGetEmpOfMonthVO" >
		<![CDATA[
			{CALL EZPERSONAL.EZSP_GETEMPOFMONTH(#v_PTERM#, #cv_1,javaType=java.sql.ResultSet,jdbcType=ORACLECURSOR,mode=OUT#)}
		]]>
	</procedure> -->
	
	<select id="EzPersonalDAO.getEmpOfMonth" parameterClass="Map"  resultClass="PersonalGetEmpOfMonthVO">
		<![CDATA[
			SELECT
				A.DISPLAYNAME ,
             	A.DISPLAYNAME2 ,
             	A.TITLE ,
             	A.TITLE2 ,
             	A.DESCRIPTION ,
             	A.DESCRIPTION2 ,
             	B.EXTENSIONATTRIBUTE2 FilePath  ,
             	A.CN 
        	FROM
        		EZPERSONAL.TBLEMPMONTH A
            JOIN
            	EZHRMASTER.TBLUSERMASTER B
            ON
            	A.CN = B.CN
       		WHERE
       			TERM = #v_PTERM#
       		AND
       			A.TENANT_ID = #tenantID#	
        	ORDER BY
        		TERM DESC
		]]>
	</select>	
	
