	<select id="EzPersonalDAO.getPollResult" parameterClass="Map"  resultClass="PersonalLightPollVO">
		<![CDATA[
			SELECT
				RESULT ,
             	COUNT(RESULT)  COUNT  
        	FROM
        		EZPERSONAL.TBLLIGHTPOLLRESULT 
       		WHERE
       			ITEMSEQ = #v_pItemSeq#
       		AND
       			TENANT_ID = #tenantID#	
        	GROUP BY
        		RESULT
        	ORDER BY
        		RESULT
		]]>
	</select>
	
	<select id="EzPersonalDAO.getPassword" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT
				PASSWORD
			FROM
				EZHRMASTER.TBLUSERMASTER
			WHERE
				CN = #cn#
