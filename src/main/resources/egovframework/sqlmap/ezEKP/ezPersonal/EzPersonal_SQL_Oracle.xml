	<select id="EzPersonalDAO.getPollInfo" parameterClass="Map"  resultClass="PersonalLightPollVO">
		<![CDATA[
			SELECT
				ITEMSEQ ,
             	STARTDATE ,
             	NVL(ENDDATE, to_date('1900-01-01', 'yyyy-MM-dd HH24:MI:SS')) EndDate  ,
             	POLLSELECTIONCOUNT ,
             	POLLTITLE ,
	            POLLTITLE2 ,
	            ANSWER1 ,
	            ANSWER2 ,
	            ANSWER3 ,
	            ANSWER4 ,
	            ANSWER5 ,
	            ANSWER6 ,
	            ANSWER7 ,
	            ANSWER8 ,
	            ANSWER9 ,
	            ANSWER10 
        	FROM
        		EZPERSONAL.TBLLIGHTPOLL 
       		WHERE
       			ITEMSEQ = #v_pItemSeq#
       		AND
       			TENANT_ID = #tenantID#	
		]]>
	</select>		
	
