	<insert id="EzScheduleDAO.insertScheduleGroupMember" parameterClass="map">
		<![CDATA[
			INSERT INTO TBL_SCHEDULEGROUPMEMBER(
				groupid, 		memberid, 		membername, 		membername2, 		status, 	responsedate,					tenant_id
			) VALUES (
				#groupID#,		#memberID#,		#memberName#,		#memberName2#,		0,			SYS_EXTRACT_UTC(SYSTIMESTAMP),	#tenantID#
			)
   		]]>
	</insert>
	
	<insert id="EzScheduleDAO.insertScheduleGroup" parameterClass="map">
		<![CDATA[
			INSERT INTO TBL_SCHEDULEGROUP(
				groupid, 		groupname, 			creatorid, 		creatorname, 		creatorname2, 		description,		createdate,						tenant_id		
			) VALUES (
				#gUID#,			#groupName#,		#userID#,		#displayName#,		#displayName2#,		#description#,		SYS_EXTRACT_UTC(SYSTIMESTAMP),	#tenantID#
			)
   		]]>
	</insert>
	
	<update id="EzScheduleDAO.updateScheduleMember" parameterClass="map">
		<![CDATA[
			UPDATE 
				TBL_SCHEDULEGROUPMEMBER
			SET
				status = #status#,
				responseDate = SYS_EXTRACT_UTC(SYSTIMESTAMP)	
	   		WHERE  
	   			groupid = #groupID#
	   		AND
	   			memberid = #memberID#	
	   		AND
	   			tenant_id = #tenantID#
		]]>	
	</update>
	
