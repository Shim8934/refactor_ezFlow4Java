	<select id="EzScheduleDAO.getMyGroupMemberListCnt" parameterClass="map" resultClass="int">
		<![CDATA[
			 SELECT 
			 	count(*)
             FROM (
	                  SELECT 
	                  	memberid 
                      FROM 
                      	TBL_SCHEDULEGROUPMEMBER 
                      WHERE  
                      	groupid = #groupID#
                      AND
                      	tenant_id = #tenantID#	
             )A JOIN TBL_USERMASTER B ON A.MemberID = B.CN
             WHERE
             	B.tenant_id = #tenantID#
		]]>
	</select>
	
	<select id="EzScheduleDAO.getMyGroupMemberList" parameterClass="map" resultMap="scheduleGroupMemberListVO">
		<![CDATA[
			 SELECT 
			 	A.memberid,
			 	'' as membername,
			 	'' as membername2,
			 	'' as status,
			 	'' as responsedate,
             	B.mail,
             	CASE #lang#
	                WHEN '1' THEN B.displayname || '(' || description || ')'
                    WHEN '2' THEN B.displayname2 || '(' || description2 || ')'   
                END info  
             FROM (
	                  SELECT 
	                  	memberid 
                      FROM 
                      	TBL_SCHEDULEGROUPMEMBER 
                      WHERE  
                      	groupid = #groupID#
                      AND
                      	tenant_id = #tenantID#	
             )A JOIN TBL_USERMASTER B ON A.MemberID = B.CN
             WHERE
             	B.tenant_id = #tenantID#
		]]>
	</select>
	
	<select id="EzScheduleDAO.getGroupMemberList" parameterClass="map" resultMap="scheduleGroupMemberListVO">
		<![CDATA[
			 SELECT 
			 	memberid,
			 	membername,
			 	membername2,
			 	status,
			 	(responsedate + #offSetMin#/(24*60)) as responsedate,
             	'' as mail,
             	'' as info  
             FROM 
             	TBL_SCHEDULEGROUPMEMBER
             WHERE
             	groupid = #groupID#
             AND
             	tenant_id = #tenantID#
		]]>
	</select>
	
	<select id="EzScheduleDAO.getDeptMemberList" parameterClass="map" resultMap="organUserVO">		
			SELECT 
			 	CN,
                CASE #lang#
	                WHEN '1' THEN displayname
                    WHEN '2' THEN displayname2    
                END displayname,
                displayname2,
                CASE #lang#
                    WHEN '1' THEN description
                    WHEN '2' THEN description2   
                END description,
                description2,
                title ,
                title2 ,
                telephonenumber 
			FROM 
				TBL_USERMASTER
            WHERE
            	<isEqual property="subDept" compareValue="Y">
            		department IN ( SELECT cn 
                                FROM 
                                	TBL_DEPTMASTER
                                WHERE  
                                	dept_cd_path LIKE '%'||#deptID#||'%' )
            	</isEqual>
            	<isNotEqual property="subDept" compareValue="Y">
            		department = #deptID#
            	</isNotEqual>           	      
			ORDER BY description		
	</select>
	
