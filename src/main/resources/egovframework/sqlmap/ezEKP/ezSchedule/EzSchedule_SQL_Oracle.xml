	<select id="EzScheduleDAO.getScheduleConfig" resultMap="scheduleConfigVO">
		<![CDATA[
			SELECT 
				defaultview,
            	startday,
             	starttime,
             	endtime,
             	autodelete 
        	FROM 
        		EZPIMS.TBLSCHEDULECONFIG 
       		WHERE  
       			userid = #userID#
       		AND
       			tenant_id = #tenantID#
		]]>
	</select>
	
	<select id="EzScheduleDAO.getScheduleGroupList" resultMap="scheduleGroupListVO">
		<![CDATA[
			SELECT 
				DISTINCT A.groupid as groupid,
				groupname,
				'' as description,
              	'' as createdate
        	FROM 
        		EZPIMS.TBLSCHEDULEGROUP A LEFT JOIN EZPIMS.TBLSCHEDULEGROUPMEMBER B ON A.GroupID = B.GroupID
       		WHERE  
       			creatorid = #userID#
            OR 
            	( memberid = #userID# AND status = 1 )
        	ORDER BY GroupName
		]]>
	</select>
	
	<select id="EzScheduleDAO.getScheduleList" parameterClass="Map" resultMap="scheduleListVO">
		<![CDATA[
			SELECT 
				scheduleid,
				parentid,
				ownerid,
				ownername,
				ownername2, 
				creatorid,
				modifierid,
				scheduletype,
				importance,
				isreadonly,
				datetype,
				startdate,
				enddate,
				repetition,
				repetitiondelete,
				title,
				location,
				ispublic
        	FROM 
        		EZPIMS.TBLSCHEDULE
       		WHERE  
       			ownerid IN ($v_PIDLIST$)
            AND 
            	(
            		(startdate >= ''|| TO_DATE(#v_PSTARTDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' AND startdate <= ''|| TO_DATE(#v_PENDDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' ) 
            		OR
            		(enddate >= ''|| TO_DATE(#v_PSTARTDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' AND enddate <  ''|| TO_DATE(#v_PENDDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'') 
            		OR
            		(startdate < ''|| TO_DATE(#v_PSTARTDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' AND enddate >=  ''|| TO_DATE(#v_PENDDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' ) 
            		OR 
            		(datetype='3')
            	)
        	ORDER BY startdate ASC
		]]>
	</select>
	
	<select id="EzScheduleDAO.getMyGroupList" parameterClass="map" resultMap="scheduleGroupListVO">
		<![CDATA[
			SELECT 
				groupid,
            	groupname,
              	description,
              	createdate
        	FROM 
        		EZPIMS.TBLSCHEDULEGROUP 
        	WHERE  
        		creatorid = #userID#
       		AND
       			tenant_id = #tenantID#
        	ORDER BY GroupName
		]]>
	</select>
	
	<select id="EzScheduleDAO.getMyGroupMemberListCnt" parameterClass="map" resultClass="int">
		<![CDATA[
			 SELECT 
			 	count(*)
             FROM (
	                  SELECT 
	                  	memberid 
                      FROM 
                      	EZPIMS.TBLSCHEDULEGROUPMEMBER 
                      WHERE  
                      	groupid = #groupID#
                      AND
                      	tenant_id = #tenantID#	
             )A JOIN EZHRMASTER.TBLUSERMASTER B ON A.MemberID = B.CN
             WHERE
             	B.tenant_id = #tenantID#
		]]>
	</select>
	
	<select id="EzScheduleDAO.getMyGroupMemberList" parameterClass="map" resultMap="scheduleGroupMemberListVO">
		<![CDATA[
			 SELECT 
			 	A.memberid,
			 	'' as membername,
			 	'' as membername2,
			 	'' as status,
			 	'' as responsedate,
             	B.mail,
             	CASE #lang#
	                WHEN '1' THEN B.displayname || '(' || description || ')'
                    WHEN '2' THEN B.displayname2 || '(' || description2 || ')'   
                END info  
             FROM (
	                  SELECT 
	                  	memberid 
                      FROM 
                      	EZPIMS.TBLSCHEDULEGROUPMEMBER 
                      WHERE  
                      	groupid = #groupID#
                      AND
                      	tenant_id = #tenantID#	
             )A JOIN EZHRMASTER.TBLUSERMASTER B ON A.MemberID = B.CN
             WHERE
             	B.tenant_id = #tenantID#
		]]>
	</select>
	
	<select id="EzScheduleDAO.getGroupMemberList" parameterClass="map" resultMap="scheduleGroupMemberListVO">
		<![CDATA[
			 SELECT 
			 	memberid,
			 	membername,
			 	membername2,
			 	status,
			 	responsedate + #offSetMin#/(24*60) as responsedate,
             	'' as mail,
             	'' as info  
             FROM 
             	EZPIMS.TBLSCHEDULEGROUPMEMBER
             WHERE
             	groupid = #groupID#
             AND
             	tenant_id = #tenantID#
		]]>
	</select>
	
	<update id="EzScheduleDAO.updateScheduleMember" parameterClass="map">
		UPDATE 
			EZPIMS.TBLSCHEDULEGROUPMEMBER
		SET
			status = #status#,
			responseDate = SYS_EXTRACT_UTC(SYSTIMESTAMP)	
   		WHERE  
   			groupid = #groupID#
   		AND
   			memberid = #memberID#	
   		AND
   			tenant_id = #tenantID#	
	</update>
	
	<delete id="EzScheduleDAO.deleteScheduleGroup" parameterClass="map">
