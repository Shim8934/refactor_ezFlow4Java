	<select id="EzScheduleDAO.getScheduleConfig" resultMap="scheduleConfigVO">
		<![CDATA[
			SELECT 
				defaultview,
            	startday,
             	starttime,
             	endtime,
             	autodelete 
        	FROM 
        		TBL_SCHEDULECONFIG 
       		WHERE  
       			userid = #userID#
       		AND
       			tenant_id = #tenantID#
		]]>
	</select>
	
	<select id="EzScheduleDAO.getScheduleGroupList" parameterClass="Map" resultMap="scheduleGroupListVO">
		<![CDATA[
			SELECT 
				DISTINCT A.groupid as groupid,
				groupname,
				'' as description,
              	'' as createdate
        	FROM 
        		TBL_SCHEDULEGROUP A LEFT JOIN TBL_SCHEDULEGROUPMEMBER B ON A.GroupID = B.GroupID AND A.tenant_id = B.tenant_id
       		WHERE  
       			(creatorid = #v_USERID# OR ( memberid = #v_USERID# AND status = 1 ))
			AND
				A.tenant_id = #v_TENANTID#       			
        	ORDER BY GroupName
		]]>
	</select>
	
	<select id="EzScheduleDAO.getScheduleList" parameterClass="Map" resultMap="scheduleListVO">
		<![CDATA[
			SELECT 
				scheduleid,
				parentid,
				ownerid,
				ownername,
				ownername2,
				creatorid,
				creatorname,
				creatorname2,
				(createdate + #offSetMin#/(24*60)) as createdate,
				modifierid,
				modifiername,
				modifiername2,
				(modifydate + #offSetMin#/(24*60)) as modifydate,
				scheduletype,
				importance,
				hasattendant,
				hasattach,
				hascomment,
				isreadonly,
				ispublic,
				datetype,
				(startdate + #offSetMin#/(24*60)) as startdate,
				(enddate + #offSetMin#/(24*60)) as enddate,
				repetition,
				repetitiondelete,
				title,
				location,
				contentpath		
        	FROM 
        		TBL_SCHEDULE
       		WHERE  
       			ownerid IN ($v_PIDLIST$)
            AND 
            	(            		
            		(startdate >= ''|| TO_DATE(#v_PSTARTDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' AND startdate <= ''|| TO_DATE(#v_PENDDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' ) 
            		OR
            		(enddate >= ''|| TO_DATE(#v_PSTARTDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' AND enddate <  ''|| TO_DATE(#v_PENDDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'') 
            		OR
            		(startdate < ''|| TO_DATE(#v_PSTARTDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' AND enddate >=  ''|| TO_DATE(#v_PENDDATE#, 'YYYY-MM-DD HH24:MI:SS') ||'' ) 
            		OR 
            		(datetype='3')            		
            	)
            ]]>	
            <isNotEmpty prepend="AND" property="v_PKEYWORD"> $v_PFILTER$ like '%'||#v_PKEYWORD#||'%' </isNotEmpty>            		
        	ORDER BY startdate ASC
	</select>
	
	<select id="EzScheduleDAO.getMyGroupList" parameterClass="map" resultMap="scheduleGroupListVO">
		<![CDATA[
			SELECT 
				groupid,
