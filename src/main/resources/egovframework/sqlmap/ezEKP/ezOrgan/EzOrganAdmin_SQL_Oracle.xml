	<select id="EzOrganAdminDAO.userCnList" resultMap="userCnList">
		<![CDATA[
			SELECT 
				a.cn
			FROM 
	    		ezHrmaster.TBLUSERMASTER a 
	    	INNER JOIN 
	    		ezHrmaster.TBLDEPTMASTER b
	    	ON a.department=b.cn
	    	ORDER BY cn
	    ]]>    		 				
	</select>
	
	<select id="EzOrganAdminDAO.companyCheck" parameterClass="String" resultClass="int">
		<![CDATA[
			SELECT 
				COUNT(cn)
     		FROM 
     			(
     				SELECT 
     					cn
     				FROM
     					ezHrmaster.TBLUSERMASTER
     				UNION
     				SELECT 
     					cn
     				FROM
     					ezHrmaster.TBLDEPTMASTER
     			 )
      		WHERE  
      			cn = #cn#
	     ]]> 
	</select>

