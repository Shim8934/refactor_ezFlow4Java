	<select id="EzOrganAdminDAO.getCompanyList" parameterClass="Map" resultClass="OrganDeptVO">
		<![CDATA[
			SELECT 
				A.CN ,
             	A.DISPLAYNAME , 
             	A.DISPLAYNAME2 
        	FROM 
        		( SELECT 
        			CN,
        			CASE #lang#
        				WHEN '1' THEN DISPLAYNAME
        				ELSE DISPLAYNAME2   
        				END DISPLAYNAME,
                    CASE #lang#
                    	WHEN '1' THEN DISPLAYNAME2
                        ELSE DISPLAYNAME   
                        END DISPLAYNAME2               
               	  FROM 
               	  	EZHRMASTER.TBLDeptmaster 
               	  WHERE
               	  	TENANT_ID = #tenantID#
               	  AND  
               	  	DEPTLEVEL = 1
               	  OR 
               	  	CN = 'Top' ) A
           	ORDER BY 
        		A.CN
		]]>
	</select>
	
