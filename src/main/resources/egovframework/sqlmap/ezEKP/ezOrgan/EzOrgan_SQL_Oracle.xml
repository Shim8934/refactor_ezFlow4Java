	<select id="EzOrganDAO.organSearch" parameterClass="Map" resultMap="deptTreeInfo">
		<isEqual property="type" compareValue="U">
			SELECT 
				cn,
				department as displayName,
				'' as extensionAttribute15,
				'user' as type				
			FROM 
	    		ezHrmaster.TBLUSERMASTER A $strSQL$
	    		 
	      	UNION ALL
	      		      	
	      	SELECT 
	      		A.cn,
	      		deptid as displayName,
	      		'' as extensionAttribute15,
	      		'user' as type
	      	FROM	
				ezHrmaster.TBLUSERMASTER B INNER JOIN ezHrmaster.TBLADDJOBMASTER A ON A.CN = B.CN $strSQL$
				
			<isEqual property="class" compareValue="all">
				UNION ALL
				
				SELECT
					cn,
					'' as displayName,
					'' as extensionAttribute15,
					'group' as type
				FROM
					ezHrmaster.TBLDEPTMASTER $strSQL$	
			</isEqual>	      				
	    </isEqual>
	    <isEqual property="type" compareValue="G">
	    	SELECT
	    		cn,
	    		'' as displayName,
	    		'' as extensionAttribute15,
	    		'group' as type
	    	FROM
	    		ezHrmaster.TBLDEPTMASTER $strSQL$
	    </isEqual>
	</select>
	
	<select id="EzOrganDAO.deptSubDeptCnt" parameterClass="String" resultClass="int">
		<![CDATA[
			SELECT 
				COUNT(cn)
     		FROM 
     			ezHrmaster.TBLDeptmaster 
      		WHERE  
      			extensionattribute1 = #deptID#
	     ]]> 
	</select>
	
	<select id="EzOrganDAO.getDeptFullPath" parameterClass="String" resultClass="String">
		<![CDATA[
			SELECT 
				'top,Top,' || dept_cd_path 
	      	FROM 
	      		ezHrmaster.TBLDEPTMASTER 
	      	WHERE  
	      		cn = #deptID#
	     ]]> 
	</select>

	<select id="EzOrganDAO.getDeptInfo" parameterClass="Map" resultClass="OrganDeptVO">
		<![CDATA[
			SELECT 
				cn ,
	            cn deptid  ,
				CASE #primary#
					WHEN '1' THEN 
						displayname
					ELSE 
						displayname2   
					END 
						displayname,
	            CASE #primary#
					WHEN '1' THEN 
						displayname
					ELSE 
						displayname2   
					END 
						deptnm,
	            displayname displayname1  ,
	            displayname2 ,
	            mail ,
	            extensionattribute1 ,
	            extensionattribute2 ,
	            extensionattribute3 ,
	            extensionattribute4 ,
	            extensionattribute5 ,
	            extensionattribute6 ,
	            extensionattribute7 ,
	            extensionattribute8 ,
	            extensionattribute9 ,
	            extensionattribute10 ,
	            extensionattribute11 ,
	            extensionattribute12 ,
	            extensionattribute13 ,
	            extensionattribute14 ,
	            extensionattribute15 ,
	            adspath ,
	            updatedt ,
	            'dept' type  
			FROM 
				ezHrmaster.TBLDEPTMASTER 
			WHERE  
				cn = #userID#
		]]>
	</select>
