<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN" "http://ibatis.apache.org/dtd/sql-map-2.dtd" >

<sqlMap namespace="ezWebFolder">
	<typeAlias  alias="FileVO"          	type="egovframework.ezEKP.ezWebFolder.vo.FileVO"/>
	<typeAlias  alias="FileTypeVO"          type="egovframework.ezEKP.ezWebFolder.vo.FileTypeVO"/>
	
	<!-- File resultMap -->
    <resultMap id="fileVO" class="FileVO">
        <result property="fileId"               column="file_id"                columnIndex="1"  />              
        <result property="fileName"         	column="file_name"              columnIndex="2"  />
        <result property="filePath"         	column="file_path"              columnIndex="3"  />
        <result property="fileSize"          	column="file_size"              columnIndex="4"  />
        <result property="typeId"          		column="type_id"                columnIndex="5"  />
        <result property="downloadCnt"          column="down_count"             columnIndex="6"  />
        <result property="fileExt"           	column="file_ext"               columnIndex="7"	 />
        <result property="folderId"           	column="folder_id"              columnIndex="8"  />
        <result property="useStatus"        	column="use_status"         	columnIndex="9"	 />
        <result property="createId"             column="create_id"            	columnIndex="10" />
        <result property="createName"           column="create_name"          	columnIndex="11" />
        <result property="createDate"           column="create_date"            columnIndex="12" />
        <result property="updateId"             column="update_id"              columnIndex="13" />
        <result property="updateDate"           column="update_date"            columnIndex="14" />        
        <result property="tenantId"         	column="tenant_id"              columnIndex="15" />
    </resultMap>
    
    <!-- FileType resultMap -->
    <resultMap id="fileTypeVO" class="FileTypeVO">
        <result property="typeId"               column="TYPE_ID"                columnIndex="1" />              
        <result property="typeName"         	column="TYPE_NAME"              columnIndex="2" />
        <result property="fileExt"         	    column="FILE_EXT"               columnIndex="3" />
        <result property="typeIcon"          	column="TYPE_ICON"              columnIndex="4" />
        <result property="tenantId"          	column="TENANT_ID"              columnIndex="5" />
    </resultMap>
    
    <insert id="EzWebFolderDAO.insertFile" parameterClass="Map">      	
        <selectKey keyProperty="v_temp" resultClass="Integer">
			<![CDATA[
				SELECT
					1 
        		FROM
        			DUAL
       			WHERE
       				NOT EXISTS (SELECT
     								FILE_ID,                               		
                               		TENANT_ID 
                        			FROM
                        				TBL_WEBFOLDER_FILE 
                         			WHERE
                         				FILE_ID = #fileId#
                                   	AND
                                   		TENANT_ID = #tenantId#
								)
			]]>
		</selectKey>   
		<isEqual property="v_temp" compareValue="1">     
        	<![CDATA[
	            INSERT INTO TBL_WEBFOLDER_FILE (
	                FILE_ID,        	FILE_NAME,         FILE_PATH,        	FILE_SIZE,          TYPE_ID,
	                DOWN_COUNT,			FILE_EXT,		   FOLDER_ID,			USE_STATUS,			CREATE_ID,       
	                CREATE_NAME,        CREATE_DATE,       UPDATE_ID,			UPDATE_DATE,        TENANT_ID
	            )
	            VALUES(
	                #fileId#,          	#fileName#,        #filePath#,          #fileSize#,         #typeId#, 
	                #downloadCnt#,		#fileExt#,		   #folderId#,			#useStatus#,		#createId#,
	                #createName#,       #createDate#,      #updateId#,      	#updateDate#,       #tenantId#
            )
        	]]>
        </isEqual>
        <isNotEqual property="v_temp" compareValue="1">
        	<![CDATA[
	            UPDATE 
	            	TBL_WEBFOLDER_FILE
	            SET 
	            	 FILE_ID 		= #fileId#,
	            	 FILE_NAME 		= #fileName#,
	            	 FILE_PATH		= #filePath#,
	            	 FILE_SIZE		= #fileSize#,
	            	 TYPE_ID		= #typeId#,
	            	 DOWN_COUNT		= #downloadCnt#,
	            	 FILE_EXT		= #fileExt#, 
	            	 FOLDER_ID		= #folderId#,
	            	 USE_STATUS 	= #useStatus#, 
	            	 CREATE_ID		= #createId#,  
	            	 CREATE_NAME	= #createName#,
	            	 CREATE_DATE	= #createDate#,
	            	 UPDATE_ID		= #updateId#,
	            	 UPDATE_DATE	= #updateDate#,	            	 
	            	 TENANT_ID		= #tenantId#
	            WHERE
	            		FILE_ID		= #fileId#
	            	AND
	            		TENANT_ID	= #tenantId#
            ]]> 
        </isNotEqual>       
    </insert>    
    
    <select id="EzWebFolderDAO.getFileSequence" resultClass="String">             
		<![CDATA[
			SELECT 
				IFNULL(MAX(CONVERT(FILE_ID, UNSIGNED INTEGER)),-1) as maxno
			FROM 
				TBL_WEBFOLDER_FILE
			WHERE  
				TENANT_ID = #tenantId#
		]]>		
    </select>  
    
    <select id="EzWebFolderDAO.getFileTypeByFileExt" resultMap="fileTypeVO">     
		<![CDATA[
			SELECT 
				*
			FROM
				tbl_webfolder_filetype
			WHERE
				FILE_EXT = #extension#
			AND
				TENANT_ID = #tenantId#
		]]>		
    </select>
    
    <select id="EzWebFolderDAO.getFileByFileId" resultMap="fileVO">   
		<![CDATA[
			SELECT 
				*
			FROM 
				TBL_WEBFOLDER_FILE
			WHERE  
				FILE_ID = #fileId#
			AND
				TENANT_ID = #tenantId#	
		]]>				
    </select>
    
    <delete id="EzWebFolderDAO.deleteFileByFileId" parameterClass="Map">
   		<![CDATA[
			DELETE FROM
				TBL_WEBFOLDER_FILE
          	WHERE
          		FILE_ID = #fileId#
			AND
				TENANT_ID = #tenantId#
		]]>
   </delete>
   
   <update id="EzWebFolderDAO.updateFileUseStatus" parameterClass="Map">
   	   	<![CDATA[
				UPDATE 
	            	TBL_WEBFOLDER_FILE
	            SET 
	            	USE_STATUS = "N"
	            WHERE
		          	FILE_ID = #fileId#
				AND
					TENANT_ID = #tenantId#
		]]>
   </update>
   
   <update id="EzWebFolderDAO.updateFileName" parameterClass="Map">
   	   	<![CDATA[
				UPDATE 
	            	TBL_WEBFOLDER_FILE
	            SET 
	            	FILE_NAME = #name#
	            WHERE
		          	FILE_ID = #fileId#
				AND
					TENANT_ID = #tenantId#
		]]>
   </update>   
</sqlMap>