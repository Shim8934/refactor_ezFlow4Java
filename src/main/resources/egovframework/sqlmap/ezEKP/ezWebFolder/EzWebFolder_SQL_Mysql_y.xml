        <result property="fileExt"           	column="file_ext"               columnIndex="7"	 />
        <result property="folderId"           	column="folder_id"              columnIndex="8"  />
        <result property="useStatus"        	column="use_status"         	columnIndex="9"	 />
        <result property="createId"             column="create_id"            	columnIndex="10" />
        <result property="createName1"          column="create_name1"          	columnIndex="11" />
        <result property="createName2"          column="create_name2"          	columnIndex="12" />
        <result property="createDate"           column="create_date"            columnIndex="13" />
        <result property="updateId"             column="update_id"              columnIndex="14" />
        <result property="updateDate"           column="update_date"            columnIndex="15" />        
        <result property="tenantId"         	column="tenant_id"              columnIndex="16" />
        <result property="fileIconUrl"          column="TYPE_ICON"        		columnIndex="17" />
<!--         <result property="updateDate"           column="update_date"            columnIndex="15" /> -->
<!--         <result property="fileTypeId"           column="filetype_id"            columnIndex="16" /> -->
<!--         <result property="fileTypeName"         column="filetype_name"          columnIndex="17" /> -->
<!--         <result property="fileIconUrl"          column="filetype_icon"          columnIndex="18" /> -->
<!--         <result property="tenantId"         	column="tenant_id"              columnIndex="19" /> -->
    </resultMap>
    
    <!-- FileType resultMap -->
    <resultMap id="folderSimpleVO" class="FolderSimpleVO">
        <result property="folderId"             column="FOLDER_ID"               columnIndex="1" />              
        <result property="folderName"         	column="FOLDER_NAME"             columnIndex="2" />
		<result property="folderLevel"         	column="FOLDER_LEVEL"            columnIndex="3" />
    </resultMap>
    
    <!-- Folder resultMap -->
    <resultMap id="folderVO" class="FolderVO">
        <result property="folderId"             column="FOLDER_ID"                columnIndex="1"  />              
        <result property="folderName1"         	column="FOLDER_NAME1"             columnIndex="2"  />
        <result property="folderName2"         	column="FOLDER_NAME2"             columnIndex="3"  />
        <result property="folderType"         	column="FOLDER_TYPE"              columnIndex="4"  />
        <result property="folderPath"          	column="FOLDER_PATH"              columnIndex="5"  />
        <result property="folderStep"           column="FOLDER_STEP"              columnIndex="6"  />
        <result property="folderLevel"          column="FOLDER_LEVEL"             columnIndex="7"  />
        <result property="folderUpper"          column="FOLDER_UPPER"             columnIndex="8"  />
        <result property="useStatus"           	column="USE_STATUS"               columnIndex="9"  />
        <result property="ownerId"        	    column="OWNER_ID"         	      columnIndex="10" />
        <result property="createId"             column="CREATE_ID"            	  columnIndex="11" />
        <result property="createDate"           column="CREATE_DATE"          	  columnIndex="12" />
        <result property="createName1"          column="CREATE_NAME1"          	  columnIndex="13" />
        <result property="createName2"          column="CREATE_NAME2"             columnIndex="14" />
        <result property="updateId"             column="UPDATE_ID"                columnIndex="15" />
        <result property="updateDate"           column="UPDATE_DATE"              columnIndex="16" />
        <result property="companyId"            column="COMPANY_ID"               columnIndex="17" />      
        <result property="tenantId"         	column="TENANT_ID"                columnIndex="18" />
    </resultMap>
    
    <!-- FolderSimple resultMap -->
    <resultMap id="fileTypeVO" class="FileTypeVO">
        <result property="typeId"               column="TYPE_ID"                columnIndex="1" />              
        <result property="typeName"         	column="TYPE_NAME"              columnIndex="2" />
        <result property="fileExt"         	    column="FILE_EXT"               columnIndex="3" />
        <result property="typeIcon"          	column="TYPE_ICON"              columnIndex="4" />
        <result property="tenantId"          	column="TENANT_ID"              columnIndex="5" />
    </resultMap>
    
    <select id="EzWebFolderDAO_y.getFileList" resultMap="fileVO" parameterClass="Map">   
   		<![CDATA[
			SELECT DISTINCT
				type.TYPE_ICON ,
				file.FILE_ID 	,
				file.FILE_NAME 	,
				file.FILE_PATH	,
				file.FILE_SIZE	,
				file.TYPE_ID	,
				file.DOWN_COUNT	,
				file.FILE_EXT	,
				file.FOLDER_ID	,
				file.USE_STATUS ,
				file.CREATE_ID	,
				file.CREATE_NAME1,
				file.CREATE_NAME2,
				file.CREATE_DATE  ,
				file.UPDATE_ID	,
				file.UPDATE_DATE  ,        	 
				file.TENANT_ID		
			FROM 
				TBL_WEBFOLDER_FILE AS file LEFT OUTER JOIN tbl_webfolder_filetype AS type ON type.TYPE_ID = file.TYPE_ID
			WHERE  
				file.FOLDER_ID = #folderId#
				
				
		]]>		
		<isNotEqual property="searchExt" compareValue="" prepend="AND">
			<![CDATA[
				file.FILE_EXT LIKE CONCAT(CONCAT('%', #searchExt#), '%')
       		]]> 
		</isNotEqual>		
		<isNotEqual property="searchCreateName" compareValue="" prepend="AND">
			<![CDATA[
				file.CREATE_NAME1 LIKE CONCAT(CONCAT('%', #searchCreateName#), '%')
       		]]> 
		</isNotEqual>		
		<isNotEqual property="searchFileType" compareValue="" prepend="AND">
			<![CDATA[
				type.TYPE_NAME LIKE CONCAT(CONCAT('%', #searchFileType#), '%')
       		]]> 
		</isNotEqual>		
		<isNotEqual property="searchFileName" compareValue="" prepend="AND">
			<![CDATA[
				file.FILE_NAME LIKE CONCAT(CONCAT('%', #searchFileName#), '%')
       		]]> 
		</isNotEqual>	
		<![CDATA[	
			AND
				file.TENANT_ID = #tenantId#	 
			ORDER BY file.CREATE_DATE LIMIT #pStart#, #pEnd#
		]]> 	
	</select>
    <select id="EzWebFolderDAO_y.getFileToTalCount" resultClass="Integer" parameterClass="Map">   
   		<![CDATA[
			select count(*) from (SELECT DISTINCT
				file.FILE_ID 	
			FROM 
				TBL_WEBFOLDER_FILE AS file right JOIN tbl_webfolder_filetype AS type ON type.TYPE_ID = file.TYPE_ID
			WHERE  
				file.FOLDER_ID = #folderId#
			AND
				file.TENANT_ID = #tenantId#	
		]]>		
		<isNotEqual property="searchExt" compareValue="" prepend="AND">
			<![CDATA[
				file.FILE_EXT LIKE CONCAT(CONCAT('%', #searchExt#), '%')
       		]]> 
		</isNotEqual>		
		<isNotEqual property="searchCreateName" compareValue="" prepend="AND">
			<![CDATA[
				file.CREATE_NAME1 LIKE CONCAT(CONCAT('%', #searchCreateName#), '%')
       		]]> 
		</isNotEqual>		
		<isNotEqual property="searchFileType" compareValue="" prepend="AND">
			<![CDATA[
				type.TYPE_NAME LIKE CONCAT(CONCAT('%', #searchFileType#), '%')
       		]]> 
		</isNotEqual>		
		<isNotEqual property="searchFileName" compareValue="" prepend="AND">
			<![CDATA[
				file.FILE_NAME LIKE CONCAT(CONCAT('%', #searchFileName#), '%')
       		]]> 
		</isNotEqual>		
			) as fileJoin
	</select>

</sqlMap>

