	</procedure>
	
	<select id="EzAddressDAO.getSubTreeInfo" parameterClass="Map" resultMap="addressFolderVO">
		<![CDATA[
			SELECT
				A.folderid, 
				A.ownerid, 
				A.foldertype, 
				A.foldername, 
				COUNT(B.folderid) as childcount
			FROM
				ezAddress.tblfoldertree A,
				ezAddress.tblfoldertree B
			WHERE 
				A.folderid = B.parentid(+) 
				AND A.parentid=#v_PARENTID# 
				AND A.ownerid=#v_OWNERID#
			GROUP BY 
				A.folderid, 
				A.ownerid, 
				A.foldertype, 
				A.foldername
		]]>
	</select>
	
	<select id="EzAddressDAO.getMaxSeq" parameterClass="Map" resultClass="Integer">
		<![CDATA[
			SELECT 
				NVL(MAX(seq), '0') 
			FROM 
				ezAddress.tblfoldertree
			WHERE 
				parentid = #v_PPARENTID#
				and ownerid = #v_POWNERID#
		]]>
	</select>
	
	<select id="EzAddressDAO.getFolderInfo" parameterClass="Map" resultClass="addressFolderVO">
		<![CDATA[
			SELECT 
				folderid, 
				parentId,
				ownerid, 
				foldertype, 
				foldername
			FROM 
				ezAddress.tblfoldertree
			WHERE 
				folderid = #v_PFOLDERID#
		]]>
	</select>
	
</sqlMap>
