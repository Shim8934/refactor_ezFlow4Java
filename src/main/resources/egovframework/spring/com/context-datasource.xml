<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:jdbc="http://www.springframework.org/schema/jdbc"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.2.xsd
						http://www.springframework.org/schema/jdbc  http://www.springframework.org/schema/jdbc/spring-jdbc-3.2.xsd">
	
	<bean id="environmentVariablesConfiguration" class="org.jasypt.encryption.pbe.config.EnvironmentStringPBEConfig">  
        <property name="algorithm" value="PBEWithMD5AndDES" />  
        <property name="password" value="enc_pass" />
	</bean>
	
	<bean id="configurationEncryptor" class="org.jasypt.encryption.pbe.StandardPBEStringEncryptor">  
        <property name="config" ref="environmentVariablesConfiguration" />  
	</bean>
	
	<!-- 환경설정 기본정보를 globals.properties 에서 참조하도록 propertyConfigurer 설정  -->
	<bean id="propertyConfigurer" class="org.jasypt.spring3.properties.EncryptablePropertyPlaceholderConfigurer">
		<constructor-arg ref="configurationEncryptor" />
        <property name="locations">
            <list>
            	<value>classpath:/egovframework/egovProps/globals.properties</value>
            	<value>classpath:/egovframework/egovProps/crypto.properties</value>            	
            	<value>classpath:/egovframework/egovProps/config.properties</value>            	
            </list>
        </property>
    </bean>

    <!-- log4j2 에서 JDBC 사용시 필요한 bean-->
    <bean id="egovConnectionFactory" class="org.egovframe.rte.fdl.logging.db.EgovConnectionFactory">
        <property name="dataSource" ref="dataSource-${Globals.DbType}${Globals.jndi}"/>
    </bean>
    
    <!-- datasource 설정(propertyConfigurer 활용) -->
    <alias name="dataSource-${Globals.DbType}${Globals.jndi}" alias="dataSource" />
    <alias name="dataSource-${Globals.DbType}${Globals.jndi}" alias="egov.dataSource" />
    
	<!-- mysql -->
    <bean id="dataSource-mysql-jndi" class="org.springframework.jndi.JndiObjectFactoryBean" lazy-init="true">
        <property name="jndiName" value="${Globals.jndiName}"/>
    </bean>
    	
    <bean id="dataSource-mysql" class="org.apache.commons.dbcp.BasicDataSource" lazy-init="true" destroy-method="close">
        <property name="driverClassName" value="${Globals.DriverClassName}"/>
        <property name="url" value="${Globals.Url}" />
        <property name="username" value="${Globals.UserName}"/>
        <property name="password" value="${Globals.Password}"/>
        <property name="validationQuery" value="select 1"></property>
        <property name="validationQueryTimeout" value="5"></property>
        <property name="timeBetweenEvictionRunsMillis" value="300000"/>
        <property name="minEvictableIdleTimeMillis" value="300000"/>
        <property name="testWhileIdle" value="true"/>        
        <property name="maxActive" value="500"/>
        <property name="maxWait" value="20000"/>
    </bean>
    
    <!-- Oracle -->
    <bean id="dataSource-oracle-jndi" class="org.springframework.jndi.JndiObjectFactoryBean" lazy-init="true">
        <property name="jndiName" value="${Globals.jndiName}"/>
    </bean>
    
    <bean id="dataSource-oracle" class="org.apache.commons.dbcp.BasicDataSource" lazy-init="true" destroy-method="close">
        <property name="driverClassName" value="${Globals.DriverClassName}"/>
        <property name="url" value="${Globals.Url}" />
        <property name="username" value="${Globals.UserName}"/>
        <property name="password" value="${Globals.Password}"/>
        <property name="validationQuery" value="select 1 from dual"></property>
        <property name="validationQueryTimeout" value="5"></property>
        <property name="timeBetweenEvictionRunsMillis" value="300000"/>
        <property name="minEvictableIdleTimeMillis" value="300000"/>
        <property name="testWhileIdle" value="true"/>        
        <property name="maxActive" value="500"/>
        <property name="maxIdle" value="500"/>
        <property name="maxWait" value="20000"/>        
    </bean>

    <!-- Tibero -->
    <bean id="dataSource-tibero-jndi" class="org.springframework.jndi.JndiObjectFactoryBean" lazy-init="true">
        <property name="jndiName" value="${Globals.jndiName}"/>
    </bean>
    
    <bean id="dataSource-tibero" class="org.apache.commons.dbcp.BasicDataSource" lazy-init="true" destroy-method="close">
        <property name="driverClassName" value="${Globals.DriverClassName}"/>
        <property name="url" value="${Globals.Url}" />
        <property name="username" value="${Globals.UserName}"/>
        <property name="password" value="${Globals.Password}"/>
        <property name="validationQuery" value="select 1 from dual"></property>
        <property name="validationQueryTimeout" value="5"></property>
        <property name="timeBetweenEvictionRunsMillis" value="300000"/>
        <property name="minEvictableIdleTimeMillis" value="300000"/>
        <property name="testWhileIdle" value="true"/>        
        <property name="maxActive" value="500"/>
        <property name="maxWait" value="20000"/>     
    </bean>
    
    <!-- Altibase -->
    <!--<bean id="dataSource-altibase" class="org.apache.commons.dbcp.BasicDataSource" destroy-method="close">
        <property name="driverClassName" value="${Globals.DriverClassName}"/>
        <property name="url" value="${Globals.Url}" />
