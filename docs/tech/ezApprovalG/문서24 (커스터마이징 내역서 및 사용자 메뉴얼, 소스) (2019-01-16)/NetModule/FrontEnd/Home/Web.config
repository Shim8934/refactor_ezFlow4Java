    <add key="USE_RECIPIENT" value="NO" />
    <!--  'YES 이면 사원추가 및 로그인시 아이디 대문자체크 사용.NO 이면 사용하지 않는다. -->
    <add key="USE_CHECKUPSTR" value="YES" />
    <!--  'YES 이면 모바일 사용 -->
