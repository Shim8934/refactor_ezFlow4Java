<?xml version="1.0" encoding="utf-8"?>
<configuration>  
  <appSettings>
  <!-- reform -->
 <add key="reformServerIP" value="127.0.0.1" />
  <add key="reformServerPort" value="8080" />
    <!-- o365 Exchange 가장 계정 -->
    <add key="o365_ImpersonatedUserId" value="" />
    <add key="o365_ImpersonatedUserPassword" value="" />
    <!-- 메일박스 용량 기본값(KB):  1(GB) * 1024 * 1024  -->
    <add key="Mail_Default_Quota" value="1048576" />
    <!--  YES: Exchange 사용, NO: 사용안함   -->
    <add key="Use_Exchange" value="YES" />
    <!-- YES: Exchange 기반 일정 사용, NO: DB 기반 일정 사용-->
    <add key="Use_Exchange_Pims" value="YES" />
    <!--  SSL 사용여부 설정 -->
    <add key="EZInfo_SSL" value="" />
    <!--  다중 로그인 방지 0 또는 1 설정 -->
    <add key="PREVENT_MULTILOGIN" value="0" />
    <!--  '시행문 변환 정의 : 이 값이 1이면 단순 변환후 인쇄' 이 값이 2이면 이것은 시행문 변환후 심사용.' 이 값이 3이면 시행문 변환후 바로 발송용.  -->
    <add key="UserInfo_Enforce" value="2" />
    <!--  '유통 중계문서 변환 양식 정의 : 사용하지 않는 경우는 빈 값("")으로 세팅함.' 이 값이 MHT이면 MHT 접수기 사용.' 이 값이 HWP이면 한글 접수기 사용.  -->
    <add key="UserInfo_RelayG_Type" value="HWP" />
    <!--  'G버전 정의  : (별도 옵션 팩키지 필요)이 값이 NO이면 표준모듈.이 값이 YES이면 G버전.이 값이 BOTH이면 개발용..   -->
    <add key="UserInfo_ApprovalG" value="YES" />
    <!--  '문서 열람 권한 정의 : 문서 열람 권한을 정의한다.1 : 공개/부분공개/비공개 권한 체크.2 : 보안등급 권한 체크.3 : 열람권한 체크.비공개 문서인 경우, 이곳에 속하면 열람 가능.속하지 않으면, 2번, 3번을 추가로 체크함.부분공개 문서인 경우, 이곳에 속하면 열람 가능.속하지 않으면, 2번, 3번을 추가로 체크함.공개 문서인 경우, 2번 3번을 추가로 체크함.-->    
    <add key="UserInfo_ApprovalG_VIEW" value="YYY" />
    <!--  'YES 이면 겸직부서 선택에 따라 결재제한. NO 이면 겸직부서 상관없이 결재가능. -->
    <add key="USE_AdditionalROle" value="NO" />
    <!--  'YES 이면 직접서명 사용. NO 이면 사용안함. -->
    <add key="USE_DirectSign" value="YES" />
    <!--  '한글 기안기의 툴바를 정의한다. 6개의 툴바로 구성. -->
    <add key="UserInfo_HWPToolbar" value="10001" />
    <!--  '메일 일반 첨부 용량 제한. -->
    <add key="MailAttachLimit" value="10" />
    <!--  '일반 첨부에서 대용량 첨부로 변경되는 용량 예)10인 경우 10MB 크기 이상의 파일을 첨부하는 경우 대용량 첨부로 처리 -->
    <add key="BigSizeMailAttachLimit" value="10" />
    <!--  '메일 대용량 첨부 용량 제한.-->
    <add key="totBigSizeMailAttachLimit" value="800" />
    <!--  '대용량 메일 첨부 삭제 일수. 예) 20인 경우 20일 이후에 삭제됨 -->
    <add key="BigSizeMailAttachDelDay" value="20" />

    <!--  'ezKMS 정의  : 이 값이 NO(YES가 아니면)이면 KMS사용 안함.  이 값이 YES이면 사용 됨.   -->
    <add key="Use_ezKMS" value="YES" />
    <!--  'YES 이면 ezDMS 사용.NO 이면 사용하지 않는다. -->
    <add key="Use_ezDMS" value="YES" />
    <!--  'YES 이면 포탈 기능 사용.NO 이면 사용하지 않는다. -->
    <add key="Use_Portal" value="YES" />    
    <!--  한글 모드에서 사용할 한/영 타이틀 -->
    <add key="lang_Primary1" value="한글" />
    <add key="lang_Secondary1" value="영문" />    
    <add key="lang_Primary2" value="Korean" />
    <add key="lang_Secondary2" value="English" />
    <add key="lang_Primary3" value="Korean" />
    <add key="lang_Secondary3" value="English" />
    <add key="lang_Primary4" value="Korean" />
    <add key="lang_Secondary4" value="English" />
    <!-- Primay 언어 설정-->
    <add key="primary" value="1" /><!--  1 : 한국어 --><!--  2 : 영어 --><!--  3 : 일본어 --><!--  4 : 중국어 -->
    <add key="USE_OCS" value="NO" />
    <!--  결재 직접 사인 펜 굵기 설정 Default : 5 -->
    <add key="AprSignPenBold" value="5" />
    <!-- Cross Browser를 지원하기 위하여 해당 Status는 사용하지 않도록 변경 -->
    <!-- HTML5 Canvas Tag에서 Color Name을 설정할 경우 IE에서 직접 서명 시 사용하는 ActiveX와 다른 색상이 나올 수 있으므로 WebColor Code를 사용하여야 함 -->
    <!--  결재 직접 사인 펜 색상 설정 Default : BLACK -->
    <!--  그외 지원 되는 색 : RED, BLUE, GREEN -->
    <add key="AprSignPenColor" value="" />
    <!-- 결재 직접 사인 펜 색상을 RGB 값으로 설정-->
    <!-- AprSignPenColorRGB 에 값이 있으면 AprSignPenColorRGB 값으로 설정됨 -->
    <!--  검정 : 0x000000 -->
    <!--  파랑 : 0xFF0000 -->
    <!--  녹색 : 0x00FF00 -->
    <!--  빨강 : 0x0000FF -->
    <add key="AprSignPenColorRGB" value="0xFF0000" />
    <!--  그룹웨어 Domain OU Path -->
    <add key="DomainOuPath" value="DC=kfi2,DC=dev" />
    <!--  대표 메일 주소 도메인 -->
    <add key="PrimaryAddressDomain" value="kfi2.dev" />
    <!--  Exchange Remote PowerShell 호출 URL -->
    <add key="PowerShellURI" value="https://GW2-MAIL.kfi2.dev/powershell" />
    <!--  Exchange 가장 계정  -->
    <add key="AdminID" value="gwadmin" />
    <!--  Exchange 가장 계정 패스워드 -->
    <add key="AdminPwd" value="P@ssw0rd1!" />
    <!--  그룹웨어 도메인 이름 -->
    <add key="DomainName" value="kfi2.dev" />
    <!--  Exchange EWS 연결 URL -->
    <add key="EWSUri" value="https://GW2-MAIL.kfi2.dev/EWS/Exchange.asmx" />
	<!--add key="EWSUri" value="https://192.168.22.13/EWS/Exchange.asmx" /-->
    <!--  Exchange 계정 연결시 계정 연결 값으로 CN, Mail 두가지 지정 -->
    <add key="LoginIDType" value="CN" />
    <!--impersonation 사용여부-->
    <add key="IsImpersonation" value="NO" />
    <!-- impersonation YES 사용 또는 Round Robin 사용 시 YES 설정 -->
    <add key="AnchorMailbox" value="NO" />
    <!--개별발신 인원수-->
    <add key="INDIVIDUALMAILUSER" value="5" />
