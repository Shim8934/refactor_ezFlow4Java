CREATE OR REPLACE VIEW 
VIEW_EZWEBFOLDER AS
SELECT
F.FILE_ID 										AS FILEID,
F.FILE_NAME 									AS FILENAME, 
CONCAT('/volumes/shared/ezFlow',F.FILE_PATH) 	AS FILEPATH, 
F.FILE_SIZE 									AS FILESIZE, 
F.CREATE_ID 									AS WRITERID,
F.CREATE_NAME1 									AS WRITERNAME, 
F.CREATE_NAME2 									AS WRITERNAME2, 
fld.COMPANY_ID 									AS COMPANYID,
DEPT.CN											AS WRITERDEPTID, 
DEPT.DISPLAYNAME								AS WRITERDEPTNAME, 
DEPT.DISPLAYNAME2								AS WRITERDEPTNAME2,
F.CREATE_DATE 									AS WRITERDATE, 
F.FOLDER_ID 									AS FOLDERID, 
F.TENANT_ID 									AS TENANTID,
FLD.FOLDER_TYPE									AS FOLDERTYPE, 
FLD.FOLDER_NAME1								AS FOLDERNAME1, 
FLD.FOLDER_NAME2								AS FOLDERNAME2
FROM TBL_WEBFOLDER_FILE F 
INNER JOIN TBL_WEBFOLDER_FOLDER FLD ON FLD.FOLDER_ID = F.FOLDER_ID AND FLD.TENANT_ID = F.TENANT_ID
INNER JOIN TBL_USERMASTER U ON U.CN = F.CREATE_ID AND U.TENANT_ID = F.TENANT_ID
INNER JOIN TBL_DEPTMASTER DEPT ON DEPT.CN = U.DEPARTMENT AND U.TENANT_ID = DEPT.TENANT_ID
WHERE FLD.USE_STATUS = 'Y' AND F.USE_STATUS = 'Y';

CREATE TABLE SEARCH_INDEX_WEBFOLDER(
	SEARCH_ID number(11) NOT NULL
    ,FILEID number(11) NOT NULL 
    ,GUBUN varchar(4) NOT NULL
    ,INSERTDATE DATE NOT null
    ,STATUS VARCHAR(4) NOT NULL
    ,TENANT_ID number(5) NOT NULL
    ,PRIMARY KEY (SEARCH_ID)
);

CREATE SEQUENCE SEARCH_WEBFOLDER_SEQ MINVALUE 1 MAXVALUE 9999999999999999999999999999
INCREMENT BY 1
START WITH 1000
NOORDER  NOCYCLE  NOKEEP  GLOBAL;

create or replace TRIGGER TBL_WEBFOLDER_FILE_SEARCH_SEQ 
BEFORE INSERT ON SEARCH_INDEX_WEBFOLDER
FOR EACH ROW
begin
if inserting then 
    if :NEW."SEARCH_ID" is null then
        select SEARCH_WEBFOLDER_SEQ.NEXTVAL INTO :NEW."SEARCH_ID" FROM DUAL;
    END IF;
END IF;
END;

create or replace TRIGGER TBL_WEBFOLDER_FILE_SEARCHING
AFTER INSERT OR DELETE OR UPDATE ON TBL_WEBFOLDER_FILE
FOR EACH ROW
BEGIN
    IF INSERTING THEN 
        INSERT INTO SEARCH_INDEX_WEBFOLDER( FILEID, GUBUN, INSERTDATE, STATUS, TENANT_ID) 
        VALUES( :new.FILE_ID, 'I', SYSDATE, 'N', :new.TENANT_ID);
    END IF;
    IF DELETING THEN 
        INSERT INTO SEARCH_INDEX_WEBFOLDER( FILEID, GUBUN, INSERTDATE, STATUS, TENANT_ID) 
        VALUES( :OLD.FILE_ID, 'D', SYSDATE, 'N', :OLD.TENANT_ID);
    END IF;
    IF UPDATING THEN 
        INSERT INTO SEARCH_INDEX_WEBFOLDER( FILEID, GUBUN, INSERTDATE, STATUS, TENANT_ID) 
        VALUES( :OLD.FILE_ID, 'U', SYSDATE, 'N', :OLD.TENANT_ID);
    END IF;
END;


